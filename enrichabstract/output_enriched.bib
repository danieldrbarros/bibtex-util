@article{avirtualspaceforchildrent2015_219,
  title = {A Virtual Space for Children to Meet and Practice Chinese},
  author = {Mei Si},
  year = {2015},
  journal = {International Journal of Artificial Intelligence in Education},
  doi = {10.1007/s40593-014-0035-7},
  url = {https://link.springer.com/article/10.1007/s40593-014-0035-7},
  item_title = {A Virtual Space for Children to Meet and Practice Chinese},
  publication_title = {International Journal of Artificial Intelligence in Education},
  item_doi = {10.1007/s40593-014-0035-7},
  authors = {Mei Si},
  publication_year = {2015},
  content_type = {Article},
  abstract = {Second language acquisition after the students have learned their first language is a unique process. One major difference between learning a foreign language and one’s mother tongue is that second language learning is often facilitated with digital media, and in particular, through interacting with computers. This project is aimed at leveraging computer game technologies and Microsoft Kinect camera to create virtual learning environments suitable for children to practice their language and culture skills. We present a unique virtual environment that contextualizes the practice and engages the learners with narratives, encourages group work and leverages the power of embodied cognition in language learning. Our system has been deployed in an afterschool program for children from 6 to 8 years old. We report our evaluation results and reflections on the deployment process, followed by discussion and future work.}
}


@incollection{whensciencechangestheimpa2015_220,
  title = {When Science Changes: The Impact of ICTs on Preparing Students for Science Outside of School},
  author = {Marie and Claire Shanahan},
  year = {2015},
  journal = {The Future in Learning Science: What’s in it for the Learner?},
  doi = {10.1007/978-3-319-16543-1_4},
  url = {https://link.springer.com/chapter/10.1007/978-3-319-16543-1_4},
  item_title = {When Science Changes: The Impact of ICTs on Preparing Students for Science Outside of School},
  publication_title = {The Future in Learning Science: What’s in it for the Learner?},
  item_doi = {10.1007/978-3-319-16543-1_4},
  authors = {Marie-Claire Shanahan},
  publication_year = {2015},
  content_type = {Chapter},
  abstract = {Discussions of the impact of information and communications technologies (ICTs) on science education have often neglected the ways in which these are changing the scientific world that students encounter outside of school. While ICTs have significant pedagogical implications, it is important to also understand how they impact the practices of science and scientists per se and the ways that students encounter these practices. This chapter uses NASA’s arsenic-based life research as a case study for how cultural practices related to critique and criticism in science, which have usually taken place in more private venues, have moved into public and classroom view. These are elements of scientific practice that students are known to have difficulty interpreting and it is argued that school science needs to make a place for more discussion of the social epistemology of science. For a world where science is communicated widely and rapidly online, where new findings can be questioned within moments of being announced, students need help not only in identifying trustworthy sources but in making sense of genuine scientific controversy.}
}


