    keywords = "Artificial intelligence; Emotion Recognition; Face recognition; Human computer interaction; Human engineering; Interactive computer graphics; Interactive computer systems; Learning systems; Serious games; Accessibility; Autism; Autism spectrum disorders; Children with autisms; Classifieds; Cognitive disability; Emotional learning; Facial expression recognition; Machine-learning; Social interactions; Color",
    correspondence_address = "T.J. Alahmadi; Department of Information Systems, College of Computer and Information Sciences, Princess Nourah bint Abdulrahman University, Riyadh, Saudi Arabia; email: tjalahmadi@pnu.edu.sa",
