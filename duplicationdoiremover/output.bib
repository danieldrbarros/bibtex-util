@article{Tatnall_2022,
    author = "Tatnall, Arthur and Fluck, Andrew",
    title = "Twenty-five years of the Education and the Information Technologies journal: Past and future",
    volume = "27",
    ISSN = "1573-7608",
    url = "http://dx.doi.org/10.1007/s10639-022-10917-9",
