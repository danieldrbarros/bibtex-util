@ARTICLE{Jaschke2024,
	author = {Jaschke, A.C. and Howlin, C. and Pool, J. and Greenberg, Y.D. and Atkinson, R. and Kovalova, A. and Merriam, E. and Pallás-Ferrer, I. and Williams, S. and Moore, C. and Hayden, K. and Allison, C. and Odell-Miller, H. and Baron-Cohen, S.},
	title = {Study protocol of a randomized control trial on the effectiveness of improvisational music therapy for autistic children},
	year = {2024},
	journal = {BMC Psychiatry},
	volume = {24},
	number = {1},
