@incollection{mobiledevices2019_178,
  title = {Mobile Devices},
  author = {Mark Pegrum},
  year = {2019},
  journal = {Mobile Lenses on Learning},
  doi = {10.1007/978-981-15-1240-7_4},
  url = {https://link.springer.com/chapter/10.1007/978-981-15-1240-7_4},
  item_title = {Mobile Devices},
  publication_title = {Mobile Lenses on Learning},
  item_doi = {10.1007/978-981-15-1240-7_4},
  authors = {Mark Pegrum},
  publication_year = {2019},
  content_type = {Chapter},
  abstract = {It is time to take a closer look at learning at the first level of the 3 Mobilities framework, where the devices are mobile but the learners and the learning experiences are not, and where the learning therefore takes place mainly in a classroom or other similar educational space. Here, there is primarily scope for personalisation (involving both customisation and agency, as per the iPAC framework; see Fig. 3.1) and for weak interaction, and the mobile devices function most often as screens (see Fig. 4.1).}
}


@incollection{intelligenttextprocessing2018_179,
  title = {Intelligent Text Processing to Help Readers with Autism},
  author = {Constantin Or and Richard Evans and Ruslan Mitkov},
  year = {2018},
  journal = {Intelligent Natural Language Processing: Trends and Applications},
  doi = {10.1007/978-3-319-67056-0_33},
  url = {https://link.springer.com/chapter/10.1007/978-3-319-67056-0_33},
  item_title = {Intelligent Text Processing to Help Readers with Autism},
  publication_title = {Intelligent Natural Language Processing: Trends and Applications},
  item_doi = {10.1007/978-3-319-67056-0_33},
  authors = {Constantin OrăsanRichard EvansRuslan Mitkov},
  publication_year = {2018},
  content_type = {Chapter},
  abstract = {Autistic Spectrum Disorder (ASD) is a neurodevelopmental disorder which has a life-long impact on the lives of people diagnosed with the condition. In many cases, people with ASD are unable to derive the gist or meaning of written documents due to their inability to process complex sentences, understand non-literal text, and understand uncommon and technical terms. This paper presents FIRST, an innovative project which developed language technology (LT) to make documents more accessible to people with ASD. The project has produced a powerful editor which enables carers of people with ASD to prepare texts suitable for this population. Assessment of the texts generated using the editor showed that they are not less readable than those generated more slowly as a result of onerous unaided conversion and were significantly more readable than the originals. Evaluation of the tool shows that it can have a positive impact on the lives of people with ASD.}
}


