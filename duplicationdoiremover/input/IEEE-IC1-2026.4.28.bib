@inproceedings{10895477,
  author    = {Jayaprakash, D. and Vignesh, J. and Kumar, G. Praveen and Ponnarasan, B. A.},
  booktitle = {2024 International Conference on Emerging Research in Computational Science (ICERCS)},
  title     = {Game Based Therapy for Autism Spectrum Disorder (ASD) Childrens Using Machine Learning},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {1-5},
  abstract  = {Game-based therapy is an emerging intervention for children's with Autism Spectrum Disorder (ASD), utilizing engaging nature of games to improve social, communication, and cognitive skills. Findings show significant improvements in engagement, social interactions, and cognitive functions. In this research evaluate the effectiveness of different machine learning algorithms to analyze therapeutic outcomes by using mobile games. The Random Forest Classifier achieved an accuracy of 91%, outperforming Artificial Neural Networks (ANN), which had 88% accuracy, and K-Nearest Neighbors (KNN), which had 85% accuracy. Based on these results, Random Forest (RF) Classifier is selected for further integration into the game-based therapy platform. The results indicate that game-based therapy, supported by the Random Forest Classifier, is a valuable complement to traditional therapies for children with ASD. Such a tool can monitor the course of the therapy, modify it as needed, and report its results. Additionally, these interactive tools provide personalized feedback, adapt to individual needs, and track progress over time.},
  keywords  = {Autism;Pediatrics;Accuracy;Machine learning algorithms;Medical treatment;Games;Artificial neural networks;Nearest neighbor methods;Random forests;Land mobile radio;Random forest Classifier;KNN Classifier;Neural Networks;Progress},
  doi       = {10.1109/ICERCS63125.2024.10895477},
  issn      = {},
  month     = {Dec}
}@inproceedings{11369559,
  author    = {Huaman, Lennin and Pomasoncco, Jasmin and Campos, Silvia},
  booktitle = {2025 International Symposium on Accreditation of Engineering and Computing Education (ICACIT)},
  title     = {Commupics: Mobile application based on the GPT-4 model to support communication in children with autism spectrum disorder aged 5 to 12 years},
  year      = {2025},
  volume    = {},
  number    = {},
  pages     = {1-5},
  abstract  = {Effective communication is one of the main challenges for children with Autism Spectrum Disorder (ASD), especially for those with limited verbal and non-verbal skills. This difficulty directly affects their social, emotional, and educational development. In recent years, artificial intelligence has begun to play a key role in inclusive educational environments by facilitating more accessible learning experiences tailored to individual needs. In this context, OpenAI’s GPT-4 model represents a significant advancement, as it combines natural language understanding with visual analysis, enabling a richer and more contextualized multimodal interaction. This technology can provide personalized responses, adaptive tutoring, and real-time multimedia support, which is especially beneficial for children with ASD by offering a flexible tool that complements traditional therapeutic and educational interventions. Its integration into specialized applications opens new possibilities for promoting the communicative and cognitive development of this population.},
  keywords  = {Autism;Visualization;Adaptation models;Image recognition;Learning (artificial intelligence);Real-time systems;Natural language processing;Mobile applications;Monitoring;Testing;Autism Spectrum Disorder;ASD;augmentative communication;PECS;mobile application;image recognition;artificial intelligence;GPT-4},
  doi       = {10.1109/ICACIT66767.2025.11369559},
  issn      = {2771-6058},
  month     = {Oct}
}@article{10821533,
  author   = {Du, Junling and Wang, Shangyu and Chen, Rentong and Wang, Shaoping},
  journal  = {IEEE Transactions on Neural Systems and Rehabilitation Engineering},
  title    = {Improving fMRI-Based Autism Severity Identification via Brain Network Distance and Adaptive Label Distribution Learning},
  year     = {2025},
  volume   = {33},
  number   = {},
  pages    = {162-174},
  abstract = {Machine learning methodologies have been profoundly researched in the realm of autism spectrum disorder (ASD) diagnosis. Nonetheless, owing to the ambiguity of ASD severity labels and individual differences in ASD severity, current fMRI-based methods for identifying ASD severity still do not achieve satisfactory performance. Besides, the potential association between brain functional networks(BFN) and ASD symptom severity remains under investigation. To address these problems, we propose a low&high-level BFN distance method and an adaptive multi-label distribution(HBFND-AMLD) technique for ASD severity identification. First, a low-level and high-level BFN distance(HBFND) is proposed to construct BFN that reflects differences in ASD severity. This method can measure the distance between the ASD and the health control(HC) on the low-order and high-order BFN respectively, which can distinguish the severity of ASD. After that, a multi-task network is proposed for ASD severity identification which considers the individual differences of ASD severity in communication and society, which considers the individual differences in language and social skills of ASD patients. Finally, a novel adaptive label distribution(ALD) technique is employed to train the ASD severity identification model, effectively preventing network overfitting by restricting label probability distribution. We evaluate the proposed framework on the public ABIDE I dataset. The promising results obtained by our framework outperform the state-of-the-art methods with an increase in identification performance, indicating that it has a potential clinical prospect for practical ASD severity diagnosis.},
  keywords = {Training;Adaptation models;Autism;Adaptive systems;Accuracy;Transfer learning;Semisupervised learning;Brain modeling;Probability distribution;Overfitting;Autism spectrum disorder;functional magnetic resonance imaging;high-level brain functional network;label distribution learning},
  doi      = {10.1109/TNSRE.2024.3516216},
  issn     = {1558-0210},
  month    = {}
}@inproceedings{10869182,
  author    = {Shen, Yun-Bo and Yu, Xiang-Lian and Liao, Xiang-Lin},
  booktitle = {2024 4th International Conference on Educational Technology (ICET)},
  title     = {Assessment and Intervention for Children with Autism: Are AI Technology Interventions Effective?},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {624-627},
  abstract  = {At present, the prevalence of autistic children remains high globally and shows an increasing trend year by year, causing a huge burden on the society. However, traditional autism intervention methods are facing a series of challenges, including the lack of human resources, uneven abilities of interventionists, and intervention methods are mostly limited to individual cases. To address these challenges, AI technology has gradually shown its importance in the field of autism intervention in recent years. This paper comprehensively explores the practical application of AI technology in autism intervention, analyzes the feasibility and potential of AI technology in this field from multiple dimensions such as early warning, assessment to intervention, and also discusses in-depth the challenges and dilemmas that AI technology may face.},
  keywords  = {Autism;Educational technology;Market research;Artificial intelligence;Faces;children with autism;AI;interventions},
  doi       = {10.1109/ICET62460.2024.10869182},
  issn      = {},
  month     = {Sep.}
}@inproceedings{9027530,
  author    = {Zhang, Mingkang and Ma, Yanbiao and Zheng, Linan and Wang, Yuanyuan and Liu, Zhihong and Ma, Jianfeng},
  booktitle = {2019 International Conference on Networking and Network Applications (NaNA)},
  title     = {Comparison of Neural Networks' Performance in Early Screening of Autism Spectrum Disorders Under Two MRI Principles},
  year      = {2019},
  volume    = {},
  number    = {},
  pages     = {338-343},
  abstract  = {Autism spectrum disorder (ASD) is a congenital neurodevelopmental disorder caused by a disorder of the nervous system. ASD is mainly characterized by developmental disorders, as well as abnormalities in social skills, communication skills, interests, and behavioral patterns. ASD is a congenital developmental disorder that cannot be completely cured by existing medical methods, and only after-day intervention can relieve its symptoms. In addition, the sooner you get the intervention, the better the patient's recovery. However, when most patients with ASD show the symptoms, they have missed the best intervention period. In order to allow the subject to be diagnosed earlier with ASD, we applied deep learning techniques to evaluate neural networks in ASD under functional magnetic resonance imaging (fMRI) imaging. At the same time, we also compared the accuracy of detection under the principle of structural magnetic resonance imaging (sMRI) imaging. Our experiments show that neural networks perform much better on fMRI data than sMRI data.},
  keywords  = {Functional magnetic resonance imaging;Convolution;Biological neural networks;Autism;Three-dimensional displays;Feature extraction;Autism Spectrum Disorder (ASD);3D Convolutional Neural Network (3D CNN);Convolutional Long Short-Term Memory (ConvLSTM);Structural Magnetic Resonance Imaging (sMRI);Functional Magnetic Resonance Imaging (fMRI)},
  doi       = {10.1109/NaNA.2019.00065},
  issn      = {},
  month     = {Oct}
}@inproceedings{10974866,
  author    = {Hegazy, Aya and Belal, Nahla and Mahar, Khaled},
  booktitle = {2024 34th International Conference on Computer Theory and Applications (ICCTA)},
  title     = {Intelligent Tools and Techniques for Teaching Children with Autism Spectrum Disorder},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {303-311},
  abstract  = {People with autism spectrum disorder (ASD) frequently struggle with restricted or repetitive behaviors or interests, as well as social communication and interaction. Additionally, they might require distinct methods for moving, learning, or focusing. Many children with ASD are intelligent enough to be average or above average, yet autism can still affect their lives and lead to disabilities in learning. Some of these learning difficulties can be effectively addressed with early interventions. For those with autism, personalized learning programs can be put in place to address learning deficits and ensure success. This paper surveys smart tools and techniques reached in the research to assist autistic patients in learning, analyzes their effectiveness, and highlights their strengths and limitations. The survey shows that many of the proposed solutions utilize robots, augmented reality, and mobile apps derived by machine learning to assist autistic children in developing communication skills and expressing their emotions more effectively. However, most systems were managed by parents who were not good observers or by therapists with less experience. This encourages certain researchers to offer observational support to increase the efficacy of ASD interventions. This paper also reviews a guideline to build an autonomous system for learning autistics that can observe the activities of the learner and provide feedback to adapt the system accordingly. Finally, an intelligent platform is proposed to assist autistic patients in learning or entertainment according to their pace and conditions.},
  keywords  = {Surveys;Autism;Pediatrics;Education;Machine learning;Learning (artificial intelligence);Observers;Mobile applications;Object recognition;Systematic literature review;Autism Spectrum Disorder;Artificial Intelligence;Autism Learning;Machine Learning;Unity;Mobile Application;Object Recognition;Humanoid Robots;Robots;Deep-Fake},
  doi       = {10.1109/ICCTA64612.2024.10974866},
  issn      = {2770-6575},
  month     = {Dec}
}@inproceedings{10775131,
  author    = {Karki, Ankit and Namitha, Kalakunnath and Singh, Kunal and Agrawal, Ronak},
  booktitle = {2024 IEEE North Karnataka Subsection Flagship International Conference (NKCon)},
  title     = {A Personalized Visual Communication App for Children with Autism},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {1-5},
  abstract  = {Autism Spectrum Disorder (ASD) is a condition that impacts interaction, communication and behavior usually showing signs, around the age of two. This paper presents a novel mobile application developed using Flutter to help children with ASD improve cognitive and communication skills through personalized, AI-powered learning modules, interactive quizzes, and visual aids. The proposed app aims to empower individuals with autism, facilitate learning and social interactions and equip parents with tools for monitoring progress. = The application includes communication features, tailored educational modules and progress monitoring capabilities. It leverages Flutter for platform functionality ensuring accessibility on both Android and iOS devices. The user friendly interface, symbols, for communication and secure parent dashboard enhance usability. Initial assessments indicate increased user engagement improved communication skills and greater independence. With a technology that offers interactive forms of communication, personalized learning modules, and dynamic assessments to match a student’s progress with their performance. This app is available for Android and iOS devices through Flutter, a technology that enables it to work in both platforms. The app is easily accessible by users due to its user-friendly layout, visual communication symbols, and secure parent dashboard. Preliminary evaluations indicate increased user participation, enhanced communication, and higher self-reliance. Compared to others apps, this one adopts a more broad approach, emphasizing communication, education, and life skills.},
  keywords  = {Performance evaluation;Autism;Visualization;Visual communication;Operating systems;Symbols;Learning (artificial intelligence);Mobile applications;Usability;Monitoring;Autism Spectrum Disorder;mobile application;Flutter;personalized learning;communication tools;visual aids;parental monitoring;adaptive learning;educational technology},
  doi       = {10.1109/NKCon62728.2024.10775131},
  issn      = {},
  month     = {Sep.}
}@inproceedings{10543652,
  author    = {M, NushkanM.N. and D., Sumadhya W. and R, Shaveesha.A. and Manathunga, Kalpani and Chamara, Didula and Gamage, Ishara},
  booktitle = {2024 IEEE 9th International Conference for Convergence in Technology (I2CT)},
  title     = {Effectiveness of Virtual Realityin Improving Learning Outcomes for Children with Autism},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {1-6},
  abstract  = {This research paper explores the efficacy of a virtual reality (VR) environment in enhancing learning outcomes for children with autism through a game-based approach. The study uses VR technology to create a more immersive and tailored educational experience for autistic children. The implications of this study are substantial, as they introduce a new and comprehensive approach to education for autistic children. The findings on the synergy between VR technology and personalized learning offer insights into how these components contribute to improved learning outcomes and increased engagement. As VR technology progresses, this research examines how VR can be effectively utilized as an inclusive educational strategy for children with autism.},
  keywords  = {Autism;Vocabulary;Atmospheric measurements;Education;Virtual environments;Speech recognition;Games;Autism spectrum disorder;Virtual Reality;Voice Recognition;Machine Learning;Game Development},
  doi       = {10.1109/I2CT61223.2024.10543652},
  issn      = {},
  month     = {April}
}@inproceedings{10064653,
  author    = {Syed, Abeer Javed and Durrani, Deenar Jawaid and Shahid, Neha and Khan, Wajahat and Muhammad, Ali},
  booktitle = {2023 Global Conference on Wireless and Optical Technologies (GCWOT)},
  title     = {Expression Detection Of Autistic Children Using CNN Algorithm},
  year      = {2023},
  volume    = {},
  number    = {},
  pages     = {1-5},
  abstract  = {Facial emotion detection is a technique for identifying human emotions from facial expressions. Autism Spectrum Disorder is an advanced neurobehavioral disorder, autism is a vast field with many problems, including hyperactivity, sensory, speech, etc. Children with autism who have behavioral problems are the focus of this research. This research is on an automatic detection system that will detect the expressions of autistic children and generate a report explaining their behaviors during their therapy sessions. This automatic system is primarily focusing on three main behavioral issues: happy, neutral, and irritated. This research is done to provide facilities to the parents, therapists, and Autistic Rehabilitation Centers to keep records of their children’s and patients’ progress in the form of reports. This is carried out using machine learning and image processing methods. The autistic children's faces are used to extract the features using local binary patterns. The proposed system uses CNN, Haar Cascade object detection Algorithm, and TensorFlow. The classification of emotions and face detection is done using the CNN algorithm and Haar Cascade object detection algorithm. Helping Hands Rehabilitation Center, a Pakistan-based autism rehabilitation center has provided its utmost assistance to make this research possible.},
  keywords  = {Wireless communication;Autism;Pediatrics;Wireless sensor networks;Machine learning algorithms;Object detection;Feature extraction;Autism;CNN;HaarCascade;Confusion Matrix},
  doi       = {10.1109/GCWOT57803.2023.10064653},
  issn      = {},
  month     = {Jan}
}@inproceedings{11380942,
  author    = {Akhila Thejaswi, R and Pakkala, Permanki Guthu Rithesh and Rai, Bellipady Shamantha and Shetty, Sudheer and Vasudeva Rao, Pv and Kulal, Navya},
  booktitle = {2025 Second International Conference on Computing, Semiconductor, Mechatronics, Intelligent Systems and Communications (COSMIC)},
  title     = {EchoSpeech: Enhancing Speech for Children with Autism and Language Disorder using Deep Learning},
  year      = {2025},
  volume    = {},
  number    = {},
  pages     = {80-85},
  abstract  = {Children with Autism Spectrum Disorder (ASD) and language difficulties face several challenges when it comes to developing communication skills, including articulating and interpreting sounds, words and sentences. Time and cost intensive treatments such as traditional language therapy where a speech language therapist meets with the child in an individual session are effective but are often not available to families in rural locations. Such limitations decrease the efficiency of the treatment as well as make it inaccessible. The proposed work EchoSpeech offers an alternative approach to traditional therapy methods with its technological base. The work uses Wav2Vec2.0 as its ASR component to convert speech into text while CNN performs image classification tasks. The CNN model reached $\mathbf{5 7. 8 1 \%}$ validation accuracy following 20 epochs of training on a image dataset. Enhanced speech recognition provides them with immediate feedback on any errors, aiding in their improvement in speaking. It also has fun game-like elements, multiple gameplay modes and levels with integrated graphics to make learning more interactive. The system monitors the progress of children, which assists in establishing individual targets for each child’s development.},
  keywords  = {Deep learning;Training;Autism;Mechatronics;Medical treatment;Speech recognition;Speech enhancement;Real-time systems;Intelligent systems;Monitoring;Deep learning;speech recognition;gamification;autism spectrum disorder;speech therapy;language disorders;and real-time feedback},
  doi       = {10.1109/COSMIC67569.2025.11380942},
  issn      = {},
  month     = {Nov}
}@inproceedings{10580412,
  author    = {Swapna, Pasam and Nanthini, S.},
  booktitle = {2024 5th International Conference on Innovative Trends in Information Technology (ICITIIT)},
  title     = {Autism Traits Detection in Toddlers: Enhanced Random Forest vs. Support Vector Machine},
  year      = {2024},
  volume    = {},
  number    = {},
  pages     = {1-5},
  abstract  = {The aim of this study is to use behavioral indicators to identify autism in toddlers at an early stage. This will be done by applying a novel Random Forest (RF) Classifier and comparing its effectiveness with the Support Vector Machine (SVM) classifier. Both algorithms are evaluated using different training and testing splits to provide predictions about the features of Autism Spectrum Disorder in young children. The Gpower test, with parameters $\alpha=0.05$ and power $=0.80$, confirms an $80 \%$ confidence level. Results show that Novel RF achieves higher accuracy of $96.4020 \%$ compared to SVM of 90.5010% for the toddler dataset. An Independent sample t-test, conducted for statistical analysis, demonstrates a substantial disparity (p=0.007, p<0.05) in the performance of Novel RF and SVM. Thus, the accuracy of Novel RF outperforms SVM. Overall, Novel RF of $96.4020 \%$ demonstrates superior performance compared to SVM of 90.5010% in detecting autism traits in toddlers.},
  keywords  = {Support vector machines;Training;Pediatrics;Autism;Accuracy;Statistical analysis;Vectors;Novel Random Forest Classifier;Support Vector Machine;Autism Spectrum Disorder(ASD);Disability;Children;ML},
  doi       = {10.1109/ICITIIT61487.2024.10580412},
  issn      = {},
  month     = {March}
}@inproceedings{11019926,
  author    = {Shiny, J. John and Thippu, H. Ashish and Sudharsandev, K. and Jordan, N. Aaron Sam},
  booktitle = {2025 Fourth International Conference on Smart Technologies, Communication and Robotics (STCR)},
  title     = {Augmented Reality Based Therapy App for children with Autism Spectrum Disorder},
  year      = {2025},
  volume    = {},
  number    = {},
  pages     = {1-6},
  abstract  = {This paper introduces an innovative and sophisticated Augmented Reality application for use in children with Autism Spectrum Disorder (ASD) diagnosis support therapy. The idea of using AR's innovative competence features to offer customised environments involving and interesting to the kids will be helpful in promoting their development of social, communication, and adaptive skills. Through the use of the SCERTS framework and adaptive learning features, the system tailors tasks according to individual performance, both in terms of usability and therapeutic impact. Preliminary feedback from therapists and parents shows enhanced interaction and visible behavioural growth. Future developments involve increasing environment variety, incorporating machine learning for dynamic adaptation, and facilitating greater accessibility through multilingual and wearable device support.},
  keywords  = {Performance evaluation;Autism;Adaptive learning;Medical treatment;Machine learning;Multilingual;Wearable devices;Usability;Augmented reality;Robots;Augmented Reality;Autism spectrum Disorder;Therapy;Emotional development;social interaction;communication;Treatment;Virtual reality},
  doi       = {10.1109/STCR62650.2025.11019926},
  issn      = {},
  month     = {May}
}@inproceedings{8966740,
  author    = {Rafique, Insha and Fatima, Kashmala and Dastagir, Anum and Mahmood, Sajid and Hussain, Muzammil},
  booktitle = {2019 International Conference on Innovative Computing (ICIC)},
  title     = {Autism Identification and Learning Through Motor Gesture Patterns},
  year      = {2019},
  volume    = {},
  number    = {},
  pages     = {1-7},
  abstract  = {Autism Spectrum Disorder (ASD) is a mental development disorder which affects the processing of information in brain causing delays in the language and reasoning development. A person's behavior can make it distinguishable if he/she has the disorder or not through three main traits i.e. social interaction, restricted/repetitive behavior or communication skills. ASD is usually diagnosed clinically on the basis of some core symptoms and tests which are expensive and can be stressful for a child. Research has shown that Autistic people can be differentiated through the difference of force in their Motor Gestures which is related to restricted/repetitive behavior of Autistic individuals. Motor disturbance is observed in autistic patients which is a key factor for us to make its identification possible through a technical early stage approach which can be very effective. A preschool level Android touch application has been developed in which the motor patterns are observed through touch sensors and inertial sensors. Ten features were obtained as kids touched the screen for the gameplay. This touch and inertial data was then analyzed by processing them through Machine Learning (ML) algorithms to classify between Autistic and Non-Autistic group on the basis of the ten features and the motor disruption was identified. This data supports the motion disruption of movements which is identified to be as a core feature of ASD (restricted/repetitive behavior) and this demonstrates that Autism is possible to be computationally assessed through an interactive and fun gameplay on a smart device. In this way we will be able to diagnose Autism through an easy to access, learning smart phone application instead of a typical, expensive clinical diagnosis.},
  keywords  = {Autism;Pediatrics;Machine learning algorithms;Force;Tactile sensors;Games;Variable speed drives;Autism Spectrum Disorder;Android touch application;Machine Learning (ML) algorithms},
  doi       = {10.1109/ICIC48496.2019.8966740},
  issn      = {},
  month     = {Nov}
}@inproceedings{10853866,
  author    = {Ahmed, Fredj and Srinivasa, Gurram and John, Danie and Prince, Shajin and D, Bini},
  booktitle = {2nd International Conference on Computer Vision and Internet of Things (ICCVIoT 2024)},
  title     = {Emotion detection in children with autism spectrum disorder: leveraging EEG signals and companion bots for enhanced interaction},
  year      = {2024},
  volume    = {2024},
  number    = {},
  pages     = {307-312},
  abstract  = {Children with Autism Spectrum Disorder (ASD) often struggle with emotional recognition and expression, which can hinder their social interactions and communication skills. Detecting emotions in children with Autism Spectrum Disorder is crucial for understanding their emotional states, as these children often face challenges in recognizing and expressing feelings. This paper explores the facial emotions and EEG signals for emotion detection with machine learning, deep learning, and physiological signal. The results show substantial accuracy in recognizing emotions by utilizing multimodal data and powerful algorithms, providing insightful information for educators and caregivers. Our goal in modifying YOLO for emotion identification is to take use of its accuracy and speed in dynamic contexts like real-time video streams. The study assesses how effectively the YOLO architectures—more especially, YOLOv5s, YOLOv7-tiny, and YOLOv8s—perform on a customized dataset intended for the identification of emotions in kids with ASD. The results demonstrate the models' efficacy in precisely recognizing emotional expressions, which supports therapeutic interventions for kids with ASD.},
  keywords  = {},
  doi       = {10.1049/icp.2024.4440},
  issn      = {},
  month     = {Dec}
}@inproceedings{9180213,
  author    = {Akhtar, Nishat and Feeney, Mairead},
  booktitle = {2020 31st Irish Signals and Systems Conference (ISSC)},
  title     = {Predictive analytics using a Machine Learning Model to recommend the most suitable Intervention Technology for Autism related deficits},
  year      = {2020},
  volume    = {},
  number    = {},
  pages     = {1-6},
  abstract  = {This body of work aims to collect and analyse data from previous studies completed on technological interventions (to aid autism related deficits such as social behaviour, communication and limited interest and actions that are both distinct and repetitive) [1] for people with Autism and a build machine learning model for predicting the most suitable intervention technology for a single or combination of deficits related to Autism. The author selected and collected all relevant data from current available studies. This data was used to build and train supervised classification machine learning model to predict the most suitable intervention technology for a single or combination of deficits related to autism based on deficits presented by an individual. Results indicated that machine learning is an effective tool for building a predictive model to recommend the most effective intervention technology for Autism related deficits based on data integrated from the studies. The outcomes have implications for medical professionals, caregivers, teachers and family members in effectively selecting technological intervention for autism related deficits. These interventions could help the individual better cope with their disability and potentially lessen its impact.},
  keywords  = {Autism;Machine learning;Predictive models;Tools;Machine learning algorithms;Sociology;Statistics;Data Analysis;Machine Learning;Supervised Classification;Ensemble Classifiers;Decision Tree;ASD interventions;Technological Interventions;Virtual Reality;Augmented Reality;Wearable assistive technology;Robot;Mobile;Serious games;Multi-media},
  doi       = {10.1109/ISSC49989.2020.9180213},
  issn      = {2688-1454},
  month     = {June}
}@inproceedings{9892186,
  author    = {Lakhani, Mohd Ismail and McDermott, James and Glavin, Frank G. and Nagarajan, Sai Priya},
  booktitle = {2022 International Joint Conference on Neural Networks (IJCNN)},
  title     = {Facial Expression Recognition of Animated Characters using Deep Learning},
  year      = {2022},
  volume    = {},
  number    = {},
  pages     = {1-9},
  abstract  = {We apply computer vision and deep learning techniques to detect occurrences of a character from animated feature films and subsequently classify its emotions. For children on the autism spectrum, being able to identify facial expressions plays a vital role in the improvement of social responsiveness. Animated Language Learning (ALL), an Ireland based company, use manually labelled images from animated feature films, in interactive software, to help teach speech and language skills to children with autism. Our motivation is to help enable the automated detection of characters and labelling of emotions to improve their workflow. To detect occurrences of a character, our method uses a custom Haar classifier. For this paper, we focus on one character. We manually delete false positives and then manually label the occurrences with five emotion labels. We analyse the inter-annotator agreement and find that this emotion classification task is difficult even for humans. We benchmark two new custom CNNs with a performance analysis against pre-trained state-of-the-art deep CNNs. The models were firstly trained and validated on images from the Toy Story movies 1 to 3, and then tested on Toy Story 4 and some related Pixar short films. As an added step, we also visualise the outputs of key neurons to help understand the best model. The experimental results show that one of our developed models out-performs the best baseline model with an accuracy value of 77.65 %.},
  keywords  = {Deep learning;Training;Autism;Head;Face recognition;Films;Toy manufacturing industry},
  doi       = {10.1109/IJCNN55064.2022.9892186},
  issn      = {2161-4407},
  month     = {July}
}@inproceedings{7877229,
  author    = {K.B., Pradeep Raj and Lahiri, Uttama},
  booktitle = {2016 7th International Conference on Intelligent Systems, Modelling and Simulation (ISMS)},
  title     = {Design of Eyegaze-Sensitive Virtual Reality Based Social Communication Platform for Individuals with Autism},
  year      = {2016},
  volume    = {},
  number    = {},
  pages     = {301-306},
  abstract  = {Deficits in adaptive social communication skills and poor dyadic eye contact are critical concerns among children with autism spectrum disorder (ASD). Also, they often exhibit high social anxiety which restricts them from socialization. Recent advancement in technologies, e.g., Virtual Reality (VR) have shown its promise in training and intervention tasks for individuals with ASD, carried out in a safe and controlled environment. In this paper, we describe the design of Eyegazesensitive VIrtual reality based Social communication Platform (E-VISP) as a proof-of-concept application dealing with some of the aspects of social communication skills for children with autism. Preliminary results of a usability study with two pairs of individuals with ASD and Typically Developing (TD) participants indicate the feasibility of our E-VISP to cause variations in their task performance, behavioral viewing (e.g., fixation duration) and gaze-related biomarkers (e.g., pupil diameter and blink-rate) that can be mapped to their individualized anxiety levels.},
  keywords  = {Avatars;Autism;Switches;Training;Usability;Data acquisition;virtual reality; eye tracking; pupil diameter; blink rate; fixation duration; autism},
  doi       = {10.1109/ISMS.2016.58},
  issn      = {2166-0670},
  month     = {Jan}
}@article{10121412,
  author   = {Welch, Karla Conn and Pennington, Robert and Vanaparthy, Saipruthvi and Do, Ha Manh and Narayanan, Rohit and Popa, Dan and Barnes, Gregory and Kuravackel, Grace},
  journal  = {IEEE Instrumentation & Measurement Magazine},
  title    = {Using Physiological Signals and Machine Learning Algorithms to Measure Attentiveness During Robot-Assisted Social Skills Intervention: A Case Study of Two Children with Autism Spectrum Disorder},
  year     = {2023},
  volume   = {26},
  number   = {3},
  pages    = {39-45},
  abstract = {Individuals with autism spectrum disorder (ASD) often face barriers in accessing opportunities across a range of educational, employment, and social contexts. One of these barriers is the development of effective communication skills sufficient for navigating the social demands of everyday environments. Fortunately, researchers have established evidence-based practices (EBP) for teaching critical communication skills to individuals with ASD [1]. One EBP that has received a great deal of attention over the last few decades is technology-aided instruction and intervention (TAII) [1], [2]. TAII is an instructional practice in which technology is an essential component and is used to facilitate behavior change. Further, it encompasses a wide range of applications including computer-assisted instruction, virtual and augmented reality, augmentative and alternative communication, and robot-assisted intervention [2].},
  keywords = {Autism;Pediatrics;Machine learning algorithms;Navigation;Employment;Education;Physiology},
  doi      = {10.1109/MIM.2023.10121412},
  issn     = {1941-0123},
  month    = {May}
}@inproceedings{11431016,
  author    = {Shuhaiber, Ahmed},
  booktitle = {2025 International Conference on Computer and Applications (ICCA)},
  title     = {Enhancing Autism Education: An Experimental Study on the Smart Heuristic Kit},
  year      = {2025},
  volume    = {},
  number    = {},
  pages     = {1-6},
  abstract  = {This study investigates the effectiveness of the Smart Heuristic Kit (SHK) in enhancing literacy skills among 50 students with Autism Spectrum Disorder (ASD, Level 1), aged 6–12 years, at an Autism center in Abu Dhabi, UAE. This experimental study focused on how students with autism spectrum disorder (ASD) responded to a three-month multimodal learning kit (SHK) intervention (October–December 2022). While reading comprehension showed only modest gains, indicating the need for additional methods, pre- and post-assessments showed considerable improvements in phonemic awareness, word identification, and speaking fluency, proving SHK's usefulness as a multimodal learning tool. Teacher response stressed the kit's usability and the significance of long-term reinforcement, while student engagement and motivation rose, demonstrating SHK's capacity to design dynamic learning experiences. In order to further optimize assistive technology for ASD learners, future research is advised to examine longitudinal outcomes, broader demographic applicability, and potential synergies with AI-driven adaptive learning systems. Overall, these findings empirically support the integration of smart assistive technologies, such as SHK, into structured ASD education program.},
  keywords  = {Autism;Adaptive learning;Educational technology;Assistive technologies;Aging;Usability;Autistic students;Smart Heuristic Kits (SHK);smart learning;Smart Pen and interactive Material},
  doi       = {10.1109/ICCA66035.2025.11431016},
