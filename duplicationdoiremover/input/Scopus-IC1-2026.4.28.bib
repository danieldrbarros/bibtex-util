@ARTICLE{Yu2025,
	author = {Yu, Xiaoxuan and Ishiwata, Tanni and Zhang, Xiaobo and Zhang, Dandan and Xu, Lijun and Su, Yi and Sha, Xiaocao},
	title = {‘More than just music’: a multimodal intervention supporting adolescents with autism spectrum disorder in a community-based program in Shanghai},
	year = {2025},
	journal = {International Journal of Developmental Disabilities},
	pages = {},
	doi = {10.1080/20473869.2025.2561160},
	url = {https://www.scopus.com/pages/publications/105018029962?origin=resultslist},
	affiliations = {Shanghai Jiao Tong University School of Medicine, Shanghai, China; Shanghai Caopeng Charity Foundation, Shanghai, China; Shanghai Conservatory of Music, Shanghai, China; Shanghai University School of Music, Shanghai, China},
	abstract = {Objectives: Autism Spectrum Disorder (ASD) affects communication, social interaction, and emotional expression, requiring multifaceted interventions. While Music Therapy (MT) is widely applied, its integration with structured education, real-life social practice, and technology-assisted methods may further enhance its effectiveness. This study evaluates the MT Plus (MT+) model developed by the Shanghai Angel Autism Salon (SAAS), which integrates traditional MT with structured academic instruction (LOVE CLASSROOM), vocational social training (A-COFFEE), and AI-assisted digital art to support adolescents with ASD. Methods: Fifty-two adolescents with ASD participated in this intervention. Pre- and post-intervention outcomes were assessed using the Autism Behavior Checklist (ABC) and Parenting Stress Index–Short Form (PSI-SF). Independent t-tests and regression analyses were conducted to evaluated changes. Results: Significant improvements were observed in sensory processing, social interaction, motor skills, language, and self-care (Cohen’s d: 1.52–2.26), with the most substantial gain in self-care (88.42%). Parental stress and dysfunctional interactions decreased, particularly in child manageability (50.54%). AI-assisted components enhanced sensory outcomes (p = 0.005), and participation in A-COFFEE led to notable development in language skills (p = 0.040). Better child behavior was associated with lower parental stress (R<sup>2</sup> = 0.325, p < 0.0001). Conclusions: The MT+ model presents a holistic, community-based approach to improving outcomes for adolescents with ASD. Further research using randomized controlled trials is recommended. These findings suggest that the MT+ intervention may offer a promising community-based model for enhancing social communication, emotional regulation, and adaptive functioning in adolescents with autism. © 2025 The British Society of Developmental Disabilities.},
	author_keywords = {adolescent rehabilitation; Autism spectrum disorder; MT+ model; multimodal intervention; social practice},
	correspondence_address = {X. Sha; Shanghai University School of Music, Shanghai, China; email: shaviolin@126.com},
	publisher = {Taylor and Francis Ltd.},
	issn = {20473869},
	coden = {NYSDA},
	language = {English},
	abbrev_source_title = {Int. J.},
	type = {Article},
	publication_stage = {Article in press},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Porayska-Pomsta2018,
	author = {Porayska-Pomsta, Kaska and Alcorn, Alyssa M. and Avramides, Katerina and Beale, Sandra and Bernardini, Sara and Foster, Mary Ellen and Frauenberger, Christopher and Good, Judith and Guldberg, Karen and Keay-Bright, Wendy and Kossyvaki, Lila and Lemon, Oliver and Mademtzi, Marilena and Menzies, Rachel and Pain, Helen and Rajendran, Gnanathusharan and Waller, Annalu and Wass, Sam and Smith, Tim J.},
