@article{Hargreaves_2020,
    author = "Hargreaves, A.",
    title = "Large-scale assessments and their effects: The case of mid-stakes tests in Ontario",
    volume = "21",
    ISSN = "1573-1812",
    url = "http://dx.doi.org/10.1007/s10833-020-09380-5",
    DOI = "10.1007/s10833-020-09380-5",
    number = "3",
    journal = "Journal of Educational Change",
    publisher = "Springer Science and Business Media LLC",
    year = "2020",
    month = "May",
    pages = "393â€“420",
    abstract = "This paper analyzes the nature and perceived effects of mid-stakes testing (known as the EQAO) in Ontario, Canada. Ontario’s mid-stakes tests were meant to ensure accountability and transparency, and assure system-wide improvement, while avoiding the negative effects and perverse incentives of their high-stakes counterparts. The paper provides new evidence from two projects covering almost a 10-year time-span in 10 of Ontario’s 72 school districts. It shows that even though mid-stakes testing is milder in its manifestations and effects than high-stakes testing, concerns remain about the need for and side effects of such testing. The findings concern two periods of Ontario educational reform. In the first period, with a specific focus on improving performance in literacy and mathematics, administrators and special education support staff felt that the assessments raised teachers’ expectations and sense of urgency leading to steady improvements in measured achievement, but that there was also evidence of negative effects, especially on paying undue attention to “bubble” students just below the threshold for minimum proficiency. In the second reform period focused on broad excellence, well-being and equity as inclusion, mid-stakes tests were perceived as having more widespread negative effects. These included teaching to the test, cultural bias, avoidance of innovation, dilemmas of whether to include highly vulnerable students in the testing process or not, and emotional ill-being among students and teachers. The paper concludes that Ontario’s twentieth century system of large scale, mid-stakes assessment has not kept pace with its twenty first century commitments to deeper learning and stronger well-being."
}

@article{Shimaya_2020,
    author = "Shimaya, Jiro and Yoshikawa, Yuichiro and Palinko, Oskar and Ogawa, Kohei and Jinnai, Nobuhiro and Ishiguro, Hiroshi",
    title = "Active Participation in Lectures via a Collaboratively Controlled Robot",
    volume = "13",
    ISSN = "1875-4805",
    url = "http://dx.doi.org/10.1007/s12369-020-00651-y",
    DOI = "10.1007/s12369-020-00651-y",
    number = "4",
    journal = "International Journal of Social Robotics",
    publisher = "Springer Science and Business Media LLC",
    year = "2020",
    month = "April",
    pages = "587â€“598",
    abstract = "Information technology, including digital devices, robots, and the internet, is of great interest in the field of education. Many previous studies have focused on improving lecturer–student communication during lectures. In this paper, we describe a new robot-teleoperation system for transferring students’ opinions or questions to the lecturer. Through this system, users can collaboratively choose a message to be uttered by a robot. We report the results of a subjective experiment performed in a controlled lecture-style environment. The results show that participation, as estimated from behavioral and subjective measures, increased in lectures using the proposed system compared with those that did not use the proposed system or employed a reduced version of the proposed system in which the robot was controlled individually (i.e., non-collaboratively)."
}

