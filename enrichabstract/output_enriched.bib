@incollection{languagelearninginthemeta2025_68,
  title = {Language Learning in the Metaverse: Research Trends, Opportunities, and Challenges},
  author = {Yu and Ju Lan},
  year = {2025},
  journal = {AI-Mediated Language Education in the Metaverse Era},
  doi = {10.1007/978-981-95-0245-5_2},
  url = {https://link.springer.com/chapter/10.1007/978-981-95-0245-5_2},
  item_title = {Language Learning in the Metaverse: Research Trends, Opportunities, and Challenges},
  publication_title = {AI-Mediated Language Education in the Metaverse Era},
  item_doi = {10.1007/978-981-95-0245-5_2},
  authors = {Yu-Ju Lan},
  publication_year = {2025},
  content_type = {Chapter},
  abstract = {The metaverse is an emerging technology that provides an immersive virtual environment for individuals to interact both with each other and with digital objects. This chapter discusses the following topics related to the metaverse and language learning. First, it describes the metaverse and explores how virtual reality can enhance student engagement, motivation, and cognitive development. Second, it explores research trends in language learning in the metaverse by discussing three systematic reviews and meta-analyses about the utilization of extended reality (XR) for language learning. Third, it suggests the direction for future research on XR for language learning. Fourth, it addresses the challenges that researchers and educators should consider when using the metaverse in language learning, including the classroom ecosystem, accessibility, negative effects, and pedagogical aims. In summary, the aim was to provide insights into the opportunities and challenges when using the metaverse for language education and to suggest future research trends.}
}


@incollection{applicationofxa0technolog2026_69,
  title = {Application of Technologies for Cognitive-Behavioural Therapies and the Treatment of Specific Learning Disorders},
  author = {Joshelyn and Paola Correa and Tenorio and Lenin and Fabian Saltos and Salazar and Lorena and Fernanda Altamirano and Ximena and Cumand and Miranda},
  year = {2026},
  journal = {AI and Computing in Industrial Education Handbook},
  doi = {10.1007/978-3-031-97015-3_19},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-97015-3_19},
  item_title = {Application of&#xa0;Technologies for&#xa0;Cognitive-Behavioural Therapies and&#xa0;the&#xa0;Treatment of&#xa0;Specific Learning Disorders},
  publication_title = {AI and Computing in Industrial Education Handbook},
  item_doi = {10.1007/978-3-031-97015-3_19},
  authors = {Joshelyn-Paola Correa-TenorioLenin-Fabian Saltos-SalazarLorena-Fernanda Altamirano-LópezXimena-Cumandá Miranda-López},
  publication_year = {2026},
  content_type = {Chapter},
  abstract = {The purpose of this study is to investigate the contribution of cognitive behavioral therapy to educational research. To this end, we have investigated the most persistent learning difficulties in students of the Gral Educational Unit Gral. Eloy Alfaro Educational Unit in the city of Salcedo. First, a bibliographic review was carried out in scientific research sources. Subsequently, 32 children were evaluated in order to identify the main learning difficulties present in three areas: calculation, reading, and writing. This process was achieved by applying the battery for the rapid assessment of developmental dyscalculia (BERDE), the battery for the assessment of writing processes (Proesc), and the battery for the assessment of reading processes (PROLEC-R). The results allowed us to identify certain tools that can be beneficial for the treatment of specific learning disorders (ASD), such as Storybird, Zooburst, among others, which have an approach centered on CBT, highlighting the great importance of a timely, appropriate, and innovative approach to the different treatments given to learning disorders within the educational environment involving technological applications.}
}


@article{opportunitiesandchallenge2021_70,
  title = {Opportunities and Challenges in Developing Technology-Based Social Skills Interventions for Adolescents with Autism Spectrum Disorder: A Qualitative Analysis of Parent Perspectives},
  author = {Roxanne and Rashedi and Kemberlee Bonnet and Rebecca and Schulte and David and Schlundt and Amy and Swanson and Amy Kinsman and Nicole Bardett and Pablo Ju and Zachary and Warren and Gautam Biswas and Maithilee Kunda},
  year = {2021},
  journal = {Journal of Autism and Developmental Disorders},
  doi = {10.1007/s10803-021-05315-y},
  url = {https://link.springer.com/article/10.1007/s10803-021-05315-y},
  item_title = {Opportunities and Challenges in Developing Technology-Based Social Skills Interventions for Adolescents with Autism Spectrum Disorder: A Qualitative Analysis of Parent Perspectives},
  publication_title = {Journal of Autism and Developmental Disorders},
  item_doi = {10.1007/s10803-021-05315-y},
  authors = {Roxanne N. RashediKemberlee BonnetRebecca J. SchulteDavid G. SchlundtAmy R. SwansonAmy KinsmanNicole BardettPablo JuárezZachary E. WarrenGautam BiswasMaithilee Kunda},
  publication_year = {2021},
  content_type = {Article}
,
  abstract = {Interest continues to be high in technology-based interventions for individuals with autism spectrum disorder (ASD). Understanding the preferences and challenges of technology use among individuals with ASD can inform the design of such interventions. Through 18 interviews with parents, we used an iterative inductive-deductive approach to qualitative analysis and explored uses of technology for social skills development among adolescents with ASD. Our findings include parents’ observations about their adolescent’s preferences in types of technology devices and digital content, as well as both positive and negative effects of technology use on mood and behavior. Parents highlighted several avenues of technological preferences and risks that may inform intervention design, enhance user engagement, and capitalize on users’ strengths while buttressing areas for growth.}
}

@incollection{definingbiasesinvisualdat2026_71,
  title = {Defining Biases in Visual Data Analysis},
  author = {Emily Wall},
  year = {2026},
  journal = {Human Bias in Visual Data Analysis},
  doi = {10.1007/978-3-032-09307-3_3},
