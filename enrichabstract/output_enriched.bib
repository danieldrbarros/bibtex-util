  item_title = {Defining Biases in Visual Data Analysis},
  publication_title = {Human Bias in Visual Data Analysis},
  item_doi = {10.1007/978-3-032-09307-3_3},
  authors = {Emily Wall},
  publication_year = {2026},
  content_type = {Chapter},
  abstract = {This chapter describes a multitude of biases that may occur throughout the visual data analysis process, informed by process models in machine learning, cognitive psychology, and visualization literature described in Chap. 2. We first provide an overview of potential sources of bias in visual data analysis, then zoom in to more specifically describe human biases from the perspective of cognitive and metacognitive deficits.}
}


@article{augmentedrealityandmobile2025_72,
  title = {Augmented Reality and Mobile Augmented Reality in Education: A Thematic Analysis of Studies in Turkey},
  author = {Pelin Yildirim and Gonca Kececi},
  year = {2025},
  journal = {SN Computer Science},
  doi = {10.1007/s42979-025-04663-1},
  url = {https://link.springer.com/article/10.1007/s42979-025-04663-1},
  item_title = {Augmented Reality and Mobile Augmented Reality in Education: A Thematic Analysis of Studies in Turkey},
  publication_title = {SN Computer Science},
  item_doi = {10.1007/s42979-025-04663-1},
  authors = {Pelin YildirimGonca Kececi},
  publication_year = {2025},
  content_type = {Article},
  abstract = {This research aims to evaluate a total of 122 master’s and doctoral theses focusing on Augmented Reality (AR) and Mobile Augmented Reality (MAR) applications in the field of education between 2020 and May 2024. The data source used was the National Thesis Center database, which centrally collects postgraduate theses in Turkey. However, full-text access to all theses was not possible during the research period, and some theses were examined only through their abstracts. Additionally, some theses are accessible only as printed copies via the Turkish Document Supply and Loan System due to confidentiality (embargo), personal preferences, or institutional policies. This situation limited the sample size and the scope of the analysis. The thesis contents were analyzed using a matrix. The results showed that master’s theses were more common than doctoral theses. While a general increase in AR and MAR-related theses was observed, a decline was recorded due to incomplete data for 2024. Studies in fields such as Computer and Instructional Technologies Education were prominent. Furthermore, various thematic focuses such as academic achievement, opinions, attitudes, and motivation in education were examined. Researchers frequently preferred quasi-experimental and mixed methods; sample sizes generally ranged from 30 to 100, and SPSS software was commonly used. To increase the number of doctoral theses in AR and MAR fields, research scholarships and support programs for doctoral students should be organized, and graduate programs and research funds should be supported.}
}


@incollection{effectofcovid19onautismsp2021_73,
  title = {Effect of COVID-19 on Autism Spectrum Disorder: Prognosis, Diagnosis, and Therapeutics Based on AI},
  author = {Ashima Sindhu Mohanty and Priyadarsan Parida and Krishna Chandra Patra},
  year = {2021},
  journal = {Applications of Artificial Intelligence in COVID-19},
  doi = {10.1007/978-981-15-7317-0_18},
  url = {https://link.springer.com/chapter/10.1007/978-981-15-7317-0_18},
  item_title = {Effect of COVID-19 on Autism Spectrum Disorder: Prognosis, Diagnosis, and Therapeutics Based on AI},
  publication_title = {Applications of Artificial Intelligence in COVID-19},
  item_doi = {10.1007/978-981-15-7317-0_18},
  authors = {Ashima Sindhu MohantyPriyadarsan ParidaKrishna Chandra Patra},
  publication_year = {2021},
  content_type = {Chapter},
  abstract = {The outbreak of coronavirus disease 2019 (COVID-19) continues to spread globally throughout. With the present ongoing research, some vital information related to neurological manifestation and symptoms associated with COVID-19 is collected. The manifestation is associated with the injury in the central nervous system (CNS) and pathophysiology of autism spectrum disorder (ASD). The COVID-19 patients show symptoms with mild, moderate, or acute illness which can result in developing respiratory distress syndrome (RDS), cardiovascular diseases, liver dysfunction, and increased level of inflammatory cytokines affecting the immune system. The neuro manifestation covers seizures, encephalitis, acute necrotizing encephalitis, transverse myelitis, and acute flaccid myelitis, which are linked with viral respiratory infections. Research still continues on about a state of neuroinflammation in the CNS when the coronavirus makes its way via the olfactory nerve and a similar condition is spotted in ASD patients. The functional change which occurs with an individual having ASD involves increase in inflammatory cytokine and unusual immune system. Further, investigation also focuses on inflammatory illness during pregnancy and the concept of Insulin-like growth factor-1 (IGF-1) in ASD. The fact is well supported that one of the primary causes of autism is the deficiency of IGF-1 in the newborn infant which results in activation of COVID-19 cytokine, Interleukin-6 (IL6). IL6 reduces immunity particularly in older patients in comparison to younger ones. ASD is a neurodevelopmental disorder that affects an average portion of world’s population but still there is an urge to analyze the pathophysiology of ASD under COVID-19. The risk factors such as comorbidities or biomarkers are to be identified which may incline an individual with COVID-19 to neurological manifestations including severity of CNS. Along with the multiple mechanism of neurological injury, this chapter also discusses the requirement of additional support towards the ASD individuals and their families during the COVID-19 outbreak. Moreover, it also focuses on the prognosis and diagnosis of ASD using AI techniques. Further, a glimpse of the therapeutics for ASD based on AI techniques is provided.}
}


@incollection{workingmemory2025_74,
  title = {Working Memory},
  author = {Jahitha Begum},
  year = {2025},
  journal = {Cognitive Control Skills for Educational Success},
  doi = {10.1007/978-981-96-6455-9_2},
  url = {https://link.springer.com/chapter/10.1007/978-981-96-6455-9_2},
  item_title = {Working Memory},
  publication_title = {Cognitive Control Skills for Educational Success},
  item_doi = {10.1007/978-981-96-6455-9_2},
  authors = {A. Jahitha Begum},
  publication_year = {2025},
  content_type = {Chapter},
  abstract = {This chapter presents one of the important CCS i.e. WM and its various aspects related to teaching learning process. The importance of memory is discussed along with types of memory and how long and short term memory related with WM. The theoretical aspects of WM are supported with different models and theories along with the role of brain are also presented. How far WM play a significant role in academic learning and achievement is well explained. The relationship between the higher cognitive abilities is supported with various research findings. Finally the ways and means of improving WM is suggested with the evidence of past research studies along with classroom practices.}
}


@article{examiningcomplexacademicl2026_75,
  title = {Examining complex academic language in children with dyslexia: a comparative analysis with curriculum standards},
  author = {Douglas and Petersen and Gwendolyn and Stout and Alisa Konishi and Therkildsen and Norma Hancock and Camryn Lettich and Tiffany Hogan},
  year = {2026},
  journal = {Annals of Dyslexia},
  doi = {10.1007/s11881-025-00357-8},
  url = {https://link.springer.com/article/10.1007/s11881-025-00357-8},
  item_title = {Examining complex academic language in children with dyslexia: a comparative analysis with curriculum standards},
  publication_title = {Annals of Dyslexia},
  item_doi = {10.1007/s11881-025-00357-8},
  authors = {Douglas B. PetersenGwendolyn H. StoutAlisa Konishi-TherkildsenNorma HancockCamryn LettichTiffany Hogan},
  publication_year = {2026},
  content_type = {Article},
  abstract = {While approximately 50% of children with dyslexia are reported to have Developmental Language Disorder (DLD), there is a possibility that a larger proportion exhibit subclinical weaknesses in complex academic language that detrimentally impact reading comprehension. This study aimed to evaluate the comprehension and production of complex academic language among school-age students with dyslexia who do and do not have DLD across discourse, sentence, and vocabulary levels, comparing their performance against established curriculum standards. Narrative retell language samples were collected from 183 students with dyslexia with and without DLD spanning first to sixth grade. We used the Narrative Language Measures-Listening subtest from the CUBED-3 to assess discourse complexity, sentence complexity, and vocabulary complexity. The findings revealed significant language deficiencies across all grades. Specifically, the majority of students failed to meet benchmark expectations for the inclusion of discourse elements, 94% to 100% of students across grade levels lacked complex sentence structures, and 82% to 100% did not incorporate complex vocabulary as expected by curriculum standards. Notably, 100% of fourth and sixth graders who had dyslexia were found to be below the expected standards in narrative discourse, sentence, and vocabulary complexity. Results also indicated that there was no significant difference between the children with dyslexia who had DLD and those who did not on discourse complexity across most grades. Minimal differences in sentence complexity and vocabulary complexity were observed between the children with dyslexia who had DLD and those who did not. When examining the percent of students with dyslexia who did not have language disorder performing below benchmark expectations, results indicated that all students except for a few first graders were below benchmark. Conclusion The high incidence of language weaknesses observed suggests that beyond the commonly recognized challenges with dyslexia, these students often struggle significantly with language skills that are critical for academic success. Therefore, systematic oral language screening and targeted language interventions are crucial in supporting the broader educational needs of children with dyslexia.}
}


@incollection{heritagelanguagesandlingu2024_76,
  title = {Heritage Languages and Linguistic Diversity: Psycholinguistic and Sociolinguistic Perspectives},
  author = {Udaya Muthyala},
  year = {2024},
