@article{ChiCTR250010505525,
author = {ChiCTR2500105055,},
title = {Establishment and Promotion of Family Intervention Service System for Children with Autism Spectrum Disorder Aged 2-9 Years Assisted by Artificial Intelligence: the Feasibility and Effect of eBSR Remote Intervention in Different Resource Areas: a Multicenter Randomized Controlled Study},
journal = {https://trialsearch.who.int/Trial2.aspx?TrialID=ChiCTR2500105055},
year = {2025},
accession_number = {ICTRP ChiCTR2500105055},
publication type = {Trial registry record},
abstract = {INTERVENTION: Intervention group:Parents assigned to the eBSR group are guided through a remote intervention based on the BSR (Behavioral‐Structured‐Social) model. The intervention lasts for 14 days, and parents are required to watch 3‐4 short video sessions per day via a dedicated app, covering three core modules: Module 1: Evidence‐based knowledge of autism, including neurodiversity awareness, evidence‐based intervention strategies, and the application of clinical assessment tools. Module 2: Core skills training based on the BSR model, such as joint attention regulation, game expansion strategies, and positive behavioral support, using a combination of live demonstration and animation. Module 3: Social skill building techniques for family scenarios based on the social ladder theory, demonstrating non‐verbal communication, two‐way interaction building and other skills in stages. During the intervention process, the system provides personalized learning progress tracking, key knowledge point testing, and AI‐assisted Q&amp;A services to ensure parental compliance and intervention fidelity.;Control group:Participants will receive a free online Caregiver Skills Training (e‐Caregiver Skills Training, eCST) course developed by the World Health Organization (WHO) on a unified dedicated platform (the same platform as the intervention group) after signing an informed consent form and completing a baseline assessment. The course also lasted 14 days. The course aims to improve caregiver‐child communication skills, especially when interacting with children with autism spectrum disorders (ASD). eCST covers modules on engaging children in activities, establishing play routines, establishing routines, and parental care, and is delivered through an online video‐learning format, with interactive session CONDITION: Autism PRIMARY OUTCOME: Quality of parent‐child interaction;Depression self‐rating scale score; SECONDARY OUTCOME: Children's Social Steps Questionnaire;Difficulty in Emotion Regulation Scale score;Parenting Efficacy Scale score; INCLUSION CRITERIA: 1. Age greater than 18 years old. 2. Adopt at least one child who has been diagnosed or suspected of having ASD or other developmental disorders by a licensed counselor or clinician in accordance with the diagnostic criteria of the Diagnostic and Statistical Manual of Mental Disorders, Fifth Edition DSM‐V. 3. Children with ASD who will be intervened between 2 and 6 years of age 4. At least 1 parent can be fluent in Mandarin and be able to understand and participate in Mandarin‐based remote intervention courses. 5. At least 1 parent is proficient in using a smartphone or computer, able to operate and participate in the eBSR remote intervention course, and has a stable Internet connection at home. 6. Parents are willing to accept the eBSR remote intervention mode for home intervention guidance, and are willing to submit parent‐child interaction videos online at baseline, outcome, and follow‐up time points.},
URL = {https://www.cochranelibrary.com/central/doi/10.1002/central/CN-02879381/full}
}


