@article{El_Wahed_2024,
    author = "El-Wahed, Eman Ezzat Abd and Ragab, Ahmed and Osman, Dalia Mostafa and El-Shourbagy, Hanan Anwar and El-Domiaty, Eman Fathi and Rashad, Asmaa El-Dessouky",
    title = "Correlation between language and cognitive skills in Egyptian children with reading problems",
    volume = "40",
    ISSN = "2090-8539",
    url = "http://dx.doi.org/10.1186/s43163-024-00633-1",
    DOI = "10.1186/s43163-024-00633-1",
    number = "1",
    journal = "The Egyptian Journal of Otolaryngology",
    publisher = "Springer Science and Business Media LLC",
    year = "2024",
    month = "August",
    abstract = "Reading problems are the most prevalent type of specific learning disability. Reading problems usually result from phonological deficits; however, it is unclear how much other linguistic abilities are impacted as well. To study different language parameters and cognitive skills in a group of Egyptian children with reading problems to better understand the difficulties that need to be considered in rehabilitation programs for those children. A case–control study was conducted on 30 children with reading problems having IQs above 85 and 30 normal control children matched for age and gender (their ages ranged from 7 to 9\&nbsp;years and 11\&nbsp;months). They underwent testing for dyslexia by the Arabic dyslexia assessment test, language evaluation using the Receptive Expressive Arabic Language Scale (REAL scale), and the Stanford-Binet intelligence scale, fifth edition. There were highly significant correlations between the severity of dyslexia and total language scores, most of REAL scale subtests. Also, highly significant correlations were detected between the severity of dyslexia and the total IQ, verbal IQ, and verbal working memory subtests. The linear regression model revealed a highly significant association between dyslexia and expressive language scaled scores, total language scaled scores, and a significant association with expressive vocabulary and understanding oral instructions subtests of REAL scale. Additionally, a highly significant association has been detected between dyslexia and the verbal working memory subtest of the Stanford-Binet test. Correlations between total language scores and intellectual abilities (total IQ, verbal IQ, and non-verbal IQ) revealed highly significant positive results. Deficits in both receptive and expressive language were observed in children with reading problems. Expressive vocabulary, listening comprehension, and verbal working memory subtests are the most affected language and cognitive skills."
}

