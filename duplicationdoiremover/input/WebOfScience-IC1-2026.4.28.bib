@inproceedings{WOS:001481466400043,
  author                     = {Hegazy, Aya and Belal, Nahla and Mahar, Khaled},
  book-group-author          = {IEEE},
  title                      = {Intelligent Tools and Techniques for Teaching Children with Autism
                                Spectrum Disorder},
  booktitle                  = {2024 34TH INTERNATIONAL CONFERENCE ON COMPUTER THEORY AND APPLICATIONS,
                                ICCTA},
  series                     = {International Conference on Computer Theory and Applications},
  year                       = {2024},
  pages                      = {303-311},
  note                       = {34th International Conference on Computer Theory and
                                Applications-ICCTA-Annual, Alexandria, EGYPT, DEC 14-16, 2024},
  organization               = {Arab Academy for Science, Technology and Maritime Transport (AASTMT)},
  abstract                   = {People with autism spectrum disorder (ASD) frequently struggle with
                                restricted or repetitive behaviors or interests, as well as social
                                communication and interaction. Additionally, they might require distinct
                                methods for moving, learning,or focusing. Many children with ASD are
                                intelligent enough tobe average or above average, yet autism can still
                                affect theirlives and lead to disabilities in learning. Some of these
                                learning difficulties can be effectively addressed with early
                                interventions. For those with autism, personalized learning programs can
                                be put in place to address learning deficits and ensure success. This
                                paper surveys smart tools and techniques reached in the research to
                                assist autistic patients in learning, analyzes their effectiveness, and
                                highlights their strengths and limitations. The survey shows that many
                                of the proposed solutions utilize robots, augmented reality, and mobile
                                apps derived by machine learning to assist autistic children in
                                developing communication skills and expressing their emotions more
                                effectively. However, most systems were managed by parents who were not
                                good observers or by therapists with less experience. This encourages
                                certain researchers to offer observational support to increase the
                                efficacyof ASD interventions. This paper also reviews a guideline to
                                buildan autonomous system for learning autistics that can observe the
                                activities of the learner and provide feedback to adapt the
                                systemaccordingly. Finally, an intelligent platform is proposed to
                                assist autistic patients in learning or entertainment according to their
