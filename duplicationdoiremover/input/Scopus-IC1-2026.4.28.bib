@ARTICLE{Khan2025,
	author = {Khan, Rayhan and Yeasmin, Sumaiya and Rony, Moustaq Karim Khan and Das, Srabani and Semi, Mst Masuma Akter and Islam, Md Azharul and Sabeena, Anseena Anees and Samiun, Md and Hasan, Rakibul},
	title = {Applicability of artificial intelligence in monitoring and improving educational performance in children with autism: a narrative review},
	year = {2025},
	journal = {International Journal of Developmental Disabilities},
	pages = {},
	doi = {10.1080/20473869.2025.2562953},
	url = {https://www.scopus.com/pages/publications/105017984851?origin=resultslist},
	affiliations = {Department of Special Education and Counseling, California State University Los Angeles, Los Angeles, CA, United States; Department of Psychology, St. Francis College, New York, NY, United States; Miyan Research Institute, International University of Business Agriculture and Technology, Dhaka, Bangladesh; Department of Education, Westcliff University, Irvine, CA, United States; Department of Business Administration, Westcliff University, Irvine, CA, United States; Department of Business Administration, International American University, San Diego, CA, United States; IEEE, Institute of Electrical and Electronics Engineers, Los Angeles, CA, United States},
	abstract = {Objectives: This narrative review aims to explore the current applications of AI in monitoring and improving educational performance in children with autism, while identifying associated benefits, challenges, and research gaps. Methods: A narrative review design was employed to analyze peer-reviewed literature published between 2015 and 2025. A comprehensive search was conducted across PubMed, Scopus, Web of Science, IEEE Xplore, and ERIC using targeted keywords. Eligible studies focusing on the educational use of AI for children with autism were assessed through thematic synthesis. Results: Findings revealed that AI technologies, including intelligent tutoring systems, computer vision, and conversational agents, enhance educational engagement, communication skills, and academic outcomes among autistic learners. AI-enabled tools also support educators by offering real-time feedback and data-driven insights. However, barriers such as data privacy concerns, algorithmic bias, infrastructural limitations, and insufficient training hinder widespread adoption. Moreover, a lack of longitudinal studies and standardized outcome measures were noted. Conclusions: AI holds significant potential to transform autism education by promoting personalized and inclusive learning. However, ethical safeguards, stakeholder involvement, and sustained research efforts are essential to ensure effective, equitable, and responsible integration. © 2025 The British Society of Developmental Disabilities.},
	author_keywords = {Artificial intelligence; autism spectrum disorder; communication skills; educational technology; ethical challenges; inclusive education; intelligent tutoring systems; personalized learning},
	correspondence_address = {M.K.K. Rony; Miyan Research Institute, International University of Business Agriculture and Technology, Dhaka, 1230, Bangladesh; email: mkkrony@yahoo.com},
	publisher = {Taylor and Francis Ltd.},
	issn = {20473869},
