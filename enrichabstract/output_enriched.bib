@incollection{intelligenteyetrackingfor2024_38,
  title = {Intelligent Eye-Tracking for the Early Diagnosis of Autism: A Mental Health Disaster with Families},
  author = {Guangtao Zhai and Huiyu Duan and Xiaoyu Ren and Pradeep Kumar Ray},
  year = {2024},
  journal = {Technology Innovation for Sustainable Development of Healthcare and Disaster Management},
  doi = {10.1007/978-981-97-2049-1_13},
  url = {https://link.springer.com/chapter/10.1007/978-981-97-2049-1_13},
  item_title = {Intelligent Eye-Tracking for the Early Diagnosis of Autism: A Mental Health Disaster with Families},
  publication_title = {Technology Innovation for Sustainable Development of Healthcare and Disaster Management},
  item_doi = {10.1007/978-981-97-2049-1_13},
  authors = {Guangtao ZhaiHuiyu DuanXiaoyu RenPradeep Kumar Ray},
  publication_year = {2024},
  content_type = {Chapter},
  abstract = {Autism spectrum disorder (ASD) is a neurodevelopmental disorder that affects an individual's social interactions, communication abilities, and behavioral patterns. This paper explores the potential of intelligent eye-tracking technology in the early diagnosis of autism and its implications for families. In recent years, intelligent eye-tracking technology, a non-invasive and objective method for assessing visual attention and social interaction patterns, has shown promise in identifying early signs of autism. This paper explores the efficacy of eye-tracking in early autism detection and its subsequent impact on families with autistic children. Through a comprehensive review of existing literature and qualitative analysis, we discuss the benefits and challenges posed by early diagnosis, the psychological impact on families, and the need for holistic support systems. Our findings suggest that while eye-tracking presents a significant advancement in early autism diagnosis, it also necessitates careful consideration of the emotional and practical needs of affected families.}
}


@article{fastandeffectiveassessmen2025_39,
  title = {Fast and effective assessment for individuals with special needs form optimization and prediction models},
  author = {Bilal Baris Alkan and Muhammet Kumartas and Serafettin Kuzucuk and Nesrin Alkan},
  year = {2025},
  journal = {BMC Psychology},
  doi = {10.1186/s40359-025-02768-z},
  url = {https://link.springer.com/article/10.1186/s40359-025-02768-z},
  item_title = {Fast and effective assessment for individuals with special needs form optimization and prediction models},
  publication_title = {BMC Psychology},
  item_doi = {10.1186/s40359-025-02768-z},
  authors = {Bilal Baris AlkanMuhammet KumartasSerafettin KuzucukNesrin Alkan},
  publication_year = {2025},
  content_type = {Article},
  abstract = {The aim of this study was to determine which items in the psychological assessment forms used by counselling and research centres for individuals with special needs are effective in classifying individuals into special needs diagnostic categories. Data were obtained from the psychological assessment request forms of 1814 individuals aged 6 to 12 years who were referred to the centre between 2019 and 2023 with suspected special needs and who were classified as having special needs based on psychological and developmental assessments. In addition, we wanted to develop new predictive models using machine learning methods based on these items. Optimizing the psychological assessment application form so that it contains fewer questions may help to make the assessment process faster and more effective. It is expected that the results of this study will make an important contribution to saving time and energy for experts and individuals.}
}

@incollection{cannabisandreproductivehe2025_40,
  title = {Cannabis and Reproductive Health: Having Patient Conversations},
  author = {Philip and Molloy},
  year = {2025},
  journal = {Cannabis and the Developing Brain},
  doi = {10.1007/978-3-031-87990-6_23},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-87990-6_23},
  item_title = {Cannabis and Reproductive Health: Having Patient Conversations},
  publication_title = {Cannabis and the Developing Brain},
  item_doi = {10.1007/978-3-031-87990-6_23},
  authors = {Philip J. Molloy},
  publication_year = {2025},
  content_type = {Chapter},
  abstract = {The Endocannabinoid System (ECS) is highly expressed in male and female reproductive tissues and plays a key role in processes related to conception and pregnancy. Cannabis use during pregnancy is increasing.

Conducting meaningful clinical research on this topic is challenging due to cannabis’ Schedule 1 status since 1970 and difficulties in conducting controlled prospective randomized studies of cannabis in the context of pregnancy. Animal models consistently show that cannabis exposure in males is associated with negative effects on testicular volume, sperm morphology, sperm motility, sperm DNA fragmentation, dysregulated sex hormone status, and seminal fluid changes. Emerging data indicate that maternal human cannabis exposure, especially early in pregnancy, is associated with adverse outcomes including low birthweight and small for gestational age, premature deliveries, and increased NICU admissions, and potential long-term neurobehavioral consequences in offspring.

There is a substantial gap in reliable information for both the public and HealthCare Providers (HCPs). For many reasons, patients often do not turn to their HCPs for information about the benefits and risks of cannabis use in the context of conception and pregnancy. HCPs are encouraged to become familiar with this topic and to educate and counsel, as appropriate, those considering or at risk for pregnancy.

}
}


@article{nurturingthenextgeneratio2025_41,
  title = {Nurturing the Next Generation of Community-Engaged Researcher Leaders},
  author = {Judith and Carta and Howard Wills and Charles and Greenwood and Constance Beecher and Lisa Bowman and Perrott and James and Lee},
  year = {2025},
  journal = {Education and Treatment of Children},
  doi = {10.1007/s43494-025-00164-1},
  url = {https://link.springer.com/article/10.1007/s43494-025-00164-1},
  item_title = {Nurturing the Next Generation of Community-Engaged Researcher Leaders},
  publication_title = {Education and Treatment of Children},
  item_doi = {10.1007/s43494-025-00164-1},
  authors = {Judith J. CartaHoward WillsCharles R. GreenwoodConstance BeecherLisa Bowman-PerrottJames D. Lee},
  publication_year = {2025},
  content_type = {Article},
  abstract = {Community-engaged research is a subspecialty of applied behavior analysis (ABA) that deals with socially important behaviors of interest to community residents, leaders, and organizations (Baer et al., Journal of Applied Behavior Analysis, 1, 91-97, 1968; Wolf, Journal of Applied Behavior Analysis, 11, 203–213, 1978). Community-engaged research today is a multidisciplinary enterprise. It requires a supply of leaders with specialized skillsets. Its core competencies encompass a range of theories, methods, analytics, and strategies that are drawn from ABA, community psychology, prevention science, and public health. Renewing the next generation of community engaged leaders at the Juniper Garden Children’s Project (JGCP) has been a high priority. Although the training of master’s and doctoral students has been ongoing since the founding of JGCP, our record of mentoring and supporting the preparation of 105 future community-engaged research leaders on externally funded professional development grants is a noteworthy accomplishment. This contribution to the special issue describes JGCP’s research leadership program (RLP) including its unique approach and outcomes. Personalizing these outcomes are the commentaries of three past mentees describing their experiences. Implications are discussed.}
}


@incollection{inclusiveandequitablegami2026_42,
  title = {Inclusive and Equitable Gamification Strategies},
  author = {Muralidhar Kurni and Ramesh Krishnamaneni and Srinivasa},
  year = {2026},
  journal = {Gamified Education},
  doi = {10.1007/978-3-032-04718-2_8},
  url = {https://link.springer.com/chapter/10.1007/978-3-032-04718-2_8},
  item_title = {Inclusive and Equitable Gamification Strategies},
  publication_title = {Gamified Education},
  item_doi = {10.1007/978-3-032-04718-2_8},
  authors = {Muralidhar KurniRamesh KrishnamaneniSrinivasa K. G.},
  publication_year = {2026},
  content_type = {Chapter},
  abstract = {Inclusive and equitable gamification is crucial for creating learning environments that acknowledge and value the diversity of learners. By tailoring gamified educational systems to be accessible to neurodiverse learners, culturally responsive, gender-inclusive, and accommodating to students with disabilities, educators can ensure that all students, regardless of their backgrounds, abilities, or identities, engage meaningfully with the content. This chapter offers comprehensive strategies for designing gamified systems that promote equity through fair reward structures, diverse narratives, and collaborative activities. The goal is to empower all students to thrive in an environment that supports their learning needs and fosters a sense of belonging and achievement. This chapter provides extensive practical examples, use cases, case studies, and specific techniques to make gamified learning inclusive and equitable for all.}
}


@article{heataheterogeneousentitya2026_43,
  title = {HEAT: a heterogeneous entity-aware transformer for efficient and accurate cloze-style machine reading comprehension},
  author = {Shima Foolad and Kourosh Kiani},
  year = {2026},
  journal = {Multimedia Tools and Applications},
  doi = {10.1007/s11042-026-21221-w},
  url = {https://link.springer.com/article/10.1007/s11042-026-21221-w},
  item_title = {HEAT: a heterogeneous entity-aware transformer for efficient and accurate cloze-style machine reading comprehension},
  publication_title = {Multimedia Tools and Applications},
  item_doi = {10.1007/s11042-026-21221-w},
  authors = {Shima FooladKourosh Kiani},
  publication_year = {2026},
  content_type = {Article},
  abstract = {Transformer models excel in machine reading comprehension but struggle with complex reasoning tasks due to the lack of explicit relational knowledge in input sequences. Existing solutions often rely on external knowledge graphs, introducing challenges in knowledge selection, availability, and processing overhead. To address this, we propose HEAT (Heterogeneous Entity-Aware Transformer), a novel method that integrates reasoning knowledge from a document-derived heterogeneous graph directly into the transformer’s self-attention mechanism, eliminating external dependencies. HEAT employs a fusion attention pattern with three components: global-local attention for word tokens, graph-based attention prioritizing entity tokens connected in the graph, and relationship-aware attention between entity and word tokens. These are enhanced by relative position labels integrated into LUKE’s entity-aware self-attention. Evaluated on ReCoRD (commonsense reasoning), WikiHop (multi-hop reasoning), and CliCR (clinical reasoning), HEAT achieves superior performance, surpassing LUKE by 1.1%, 5.6%, and 2.2%, respectively, and outperforming LUKE-Graph, demonstrating its effectiveness in reasoning-intensive tasks.}
}


