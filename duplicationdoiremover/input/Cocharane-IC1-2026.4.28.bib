@article{Mudiginty21,
author = {Mudiginty, P, Balamurugen, P, Selvan, P, and Selvan, SR},
title = {Application of Varma Kalai (art of vital points) in autism spectrum disorder},
journal = {European journal of integrative medicine},
volume = {41},
year = {2021},
accession_number = {EMBASE 2010377201},
publication type = {Journal article},
keywords = {*Ayurveda; *autism /diagnosis /therapy; *varma kalai; Adolescent; Article; Automutilation; Case report; Child; Clinical article; Cognition; Communication skill; Cost effectiveness analysis; Developmental delay /diagnosis; Feedback system; Female; Follow up; Gluten free diet; Human; Language ability; Male; Occupational therapy; Physiotherapy; Priority journal; School child; Sleep quality; Social behavior; Social competence},
abstract = {Introduction: Autism spectrum disorder (ASD) is a neurobehavioral disorder with deficits in the neural networks of the brain. Varma Kalai, a distinct branch of ancient Siddha System of Medicine, involves manipulation of energy points on the body to heal, and/or revive from injury. This paper introduces the science of Varma Kalai and its potential therapeutic application in ASD. Methods: Based on Siddha texts and traditional practices, we observed the effects of Varma Kalai application in four ASD participants, males ages 3, 4, 7 and 11 years. The procedure involved non‐invasive physical manipulation of 14 points between brain and spine. Intervention was given once a day at bedtime by their caregiver/parent over a period of 4 weeks, minimum. Observations were based on comparing parameters in initial and follow up questionnaires (4 weeks) and also verbal, email and in‐person appointments/communications over 4 months. Results: Varma Kalai therapy in ASD has shown promising improvements in select areas of cognitive functions like social behaviors, language and communication skills, and physical functions. No side effects were reported. Conclusion: Varma Kalai application for ASD is simple, cost‐effective, non‐invasive, and safe therapy as revealed in the cases presented in this report. Encouraging feedback in the cases paves way for urgent examination of the etiology of the devastating condition of ASD through the lens of Siddha medicine to better understand this complex disorder and to develop more effective and safer treatments. To further systematically study the application of Varma Kalai in ASD, randomized controlled clinical trials are warranted.},
DOI = {10.1016/j.eujim.2020.101231},
URL = {https://www.cochranelibrary.com/central/doi/10.1002/central/CN-02210212/full}
}


