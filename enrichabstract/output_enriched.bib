@article{challengesandopportunitie2023_63,
  title = {Challenges and opportunities of AI in inclusive education: a case study of data-enhanced active reading in Japan},
  author = {Yuko Toyokawa and Izumi Horikoshi and Rwitajit Majumdar and Hiroaki Ogata},
  year = {2023},
  journal = {Smart Learning Environments},
  doi = {10.1186/s40561-023-00286-2},
  url = {https://link.springer.com/article/10.1186/s40561-023-00286-2},
  item_title = {Challenges and opportunities of AI in inclusive education: a case study of data-enhanced active reading in Japan},
  publication_title = {Smart Learning Environments},
  item_doi = {10.1186/s40561-023-00286-2},
  authors = {Yuko ToyokawaIzumi HorikoshiRwitajit MajumdarHiroaki Ogata},
  publication_year = {2023},
  content_type = {Article}
,
  abstract = {In inclusive education, students with different needs learn in the same context. With the advancement of artificial intelligence (AI) technologies, it is expected that they will contribute further to an inclusive learning environment that meets the individual needs of diverse learners. However, in Japan, we did not find any studies exploring current needs in an actual special needs context. In this study, we used the learning and evidence analysis framework (LEAF) as a learning analytics-enhanced learning environment and employed Active Reading as an example learning task to investigate the challenges and possibilities of applying AI to inclusive education in the future. Two students who attended a resource room formed the context. We investigated learning logs in the LEAF system while each student executed a given learning task. We detected specific learning behaviors from the logs and explored the challenges and future potential of learning with AI technology, considering human involvement in orchestrating inclusive educational practices.}
}

@article{augmentedrealityforstoryr2026_64,
  title = {Augmented reality for story-related activities in primary and secondary education: a systematic review},
  author = {Eirini Christou and Antigoni Parmaxi and Lawrence and Farrugia Caruana and Leonard Busuttil and Jacqueline and Sonia Rodr and Cano and Vanesa Delgado and Benito and Laura Alonso and Mart and Andri Ioannou},
  year = {2026},
  journal = {Universal Access in the Information Society},
  doi = {10.1007/s10209-025-01290-8},
  url = {https://link.springer.com/article/10.1007/s10209-025-01290-8},
  item_title = {Augmented reality for story-related activities in primary and secondary education: a systematic review},
  publication_title = {Universal Access in the Information Society},
  item_doi = {10.1007/s10209-025-01290-8},
  authors = {Eirini ChristouAntigoni ParmaxiLawrence  Farrugia CaruanaLeonard BusuttilJacqueline ŻammitSonia Rodríguez-CanoVanesa Delgado-BenitoLaura Alonso-MartínezAndri Ioannou},
  publication_year = {2026},
  content_type = {Article}
,
  abstract = {Story-related activities such as storytelling, story creation and narrative-based learning have become a popular pedagogical approach used in education. Additionally, Augmented Reality (AR) is a tool that receives significant attention globally. Recognizing this trend, researchers have been seeking ways to integrate story-related activities with AR in educational contexts. This paper presents a systematic literature review focusing on the use of AR in story-related activities within primary and secondary education. By conducting a systematic search of studies published in the past 5 years between 2019 and 2024, 264 relevant papers were initially identified. After applying inclusion, exclusion and quality criteria, 39 studies were selected for in-depth analysis. Framed by the principles of learning experience design, this review explores how AR is integrated into story-based educational practices, highlighting its current applications, benefits, and barriers. Additionally, the review critically reflects on the need to prioritise pedagogy over technological features when designing AR-enhanced learning experiences. The study concludes with recommendations for future research and practical insights for educators aiming to incorporate AR into story-related educational activities.}
}

@article{evaluatingaugmentedrealit2025_65,
  title = {Evaluating augmented reality in physical education for dyslexic students from the perspectives of teachers and students},
  author = {Nur Azlina Mohamed Mokmin and Regania Pasca Rassy and Darren Lim Yie},
  year = {2025},
  journal = {Scientific Reports},
  doi = {10.1038/s41598-025-92533-4},
  url = {https://link.springer.com/article/10.1038/s41598-025-92533-4},
  item_title = {Evaluating augmented reality in physical education for dyslexic students from the perspectives of teachers and students},
  publication_title = {Scientific Reports},
  item_doi = {10.1038/s41598-025-92533-4},
  authors = {Nur Azlina Mohamed MokminRegania Pasca RassyDarren Lim Yie},
  publication_year = {2025},
  content_type = {Article}
,
  abstract = {Students with dyslexia (SWDs), which is a specific learning problem that impairs reading, often experience inadequate academic performance and have a negative perception of themselves in general. However, despite the recognized benefits of Physical Education (PE) classes for physical and psychological development towards SWDs, barriers such as fear of injury, limited resources, and a shortage of trained teachers undermine the inclusivity of PE programs. The present study aims to uncover the issues when teaching PE using the traditional approach and investigate the possible opportunities, challenges, and effectiveness of integrating augmented reality (AR) technology in PE classes. SWDs (n = 22) and PE teachers (n = 2) were selected using purposive sampling, and interview sessions were conducted before and after the intervention. The transcription of the recorded sessions was then analyzed using thematic analysis, and a thematic map was constructed based on the findings. The implementation of AR in PE instruction has the potential to create a more inclusive learning environment, breaking down barriers and promoting the overall well-being of SWDs in Malaysian schools.}
}

@incollection{telehealthandappliedbehav2023_66,
  title = {Telehealth and Applied Behavior Analysis: An Overview and Examples of Application},
  author = {Joy Pollard and Shawn Quigley and Matthew and Brien and Stephanie Peterson and Sean Casey},
  year = {2023},
  journal = {Handbook of Applied Behavior Analysis},
  doi = {10.1007/978-3-031-19964-6_40},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-19964-6_40},
  item_title = {Telehealth and Applied Behavior Analysis: An Overview and Examples of Application},
  publication_title = {Handbook of Applied Behavior Analysis},
  item_doi = {10.1007/978-3-031-19964-6_40},
  authors = {Joy PollardShawn QuigleyMatthew O’BrienStephanie PetersonSean Casey},
  publication_year = {2023},
  content_type = {Chapter},
  abstract = {Throughout history, humans have utilized technology to stay connected. A specific application of technology and connectedness is providing care, education, and administration across distances. This general application is referred to as telehealth, and professionals from many disciplines utilize telehealth models (e.g., telemedicine, telepsychology). Behavior analytic professionals are no exception. This chapter provides a broad overview of telehealth, identification of some telehealth service delivery models, considerations of telehealth service delivery, and concludes with examples of behavior analytic applications via telehealth. The applications are discussed in the broad domains of severe and challenging behavior, skill acquisition, feeding and nutrition, clinical behavior analysis, and education and professional development. Each domain provides example research, application, and discussion of future needs.}
}


