@incollection{howdoyoubuildagroupprogra2019_186,
  title = {How Do You Build a Group Program Based on the Principles of Intrinsic Motivation? Developing an After-School Program to Meet the Needs of all Students: Eight Years of Development},
  author = {Elaine Clanton Harpine},
  year = {2019},
  journal = {After-School Programming and Intrinsic Motivation},
  doi = {10.1007/978-3-030-22845-3_4},
  url = {https://link.springer.com/chapter/10.1007/978-3-030-22845-3_4},
  item_title = {How Do You Build a Group Program Based on the Principles of Intrinsic Motivation? Developing an After-School Program to Meet the Needs of all Students: Eight Years of Development},
  publication_title = {After-School Programming and Intrinsic Motivation},
  item_doi = {10.1007/978-3-030-22845-3_4},
  authors = {Elaine Clanton Harpine},
  publication_year = {2019},
  content_type = {Chapter},
  abstract = {Many communities lack adequate after-school programs, especially after-school programs that help children improve academically. To answer this need, our university research team collaborated with two community sponsors to develop an effective after-school program for students who were failing in reading. Some of the children had failed for multiple years. The goal was to bring children up to their appropriate age level in reading and to develop something that could be an ongoing, long-term self-sustaining program for the community. Across eight years, we developed, implemented, and tested an after-school group-centered prevention model, using a program packet to facilitate training with a community volunteer staff. The first-person accounts included in this article describe the development of the program and the development of the volunteer staff needed to continue the program. We present a model that can be used by any community to develop a similar program. The success of our model focused on using a group-centered prevention format, stressing intrinsic motivation, and teaching vowel clustering.}
}


