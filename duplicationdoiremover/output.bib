    author = "Sandygulova, Anara and Amir, Aida and Oralbayeva, Nurziya and Telisheva, Zhansaule and Zhanatkyzy, Aida and Shakerimov, Aidar and Sarmonov, Shamil and Aimysheva, Arna",
