@inproceedings{10.5555/2729485.2729509,
    author = "schraefel, m.c.",
    title = "Burn the chair, we're wired to move: exploring the brain/body connexion for HCI creativity \&amp; cognition",
    year = "2014",
    isbn = "9788968487521",
    publisher = "Hanbit Media, Inc.",
    address = "Seoul, KOR",
    abstract = {A goal of Human Computer Interaction / Human Factors research with respect to creativity and cognition has been to develop principled heuristics that can both inform design of software, hardware and their environments, as well as offer a foundation for evaluation metrics. Work in two areas seems to offer strong candidates for a principled design and evaluative approach to creativity based on neural-cognitive analysis: (a) neuroscience in its mapping of creative acts to brain area and function, and (b) human performance assessing physical activity on cognition. In this paper we review the research in both these areas and propose example opportunities for design and evaluation informed by this research. We suggest as well both that the creativity and cognition community is ideally placed to extend neural "creativity cognition" research and that working from such a foundation may significantly reconfigure knowledge work software, hardware and work environment design.},
    booktitle = "Proceedings of HCI Korea",
    pages = "153–161",
    numpages = "9",
    keywords = "neuroscience, human performance, creativity, cognition",
    location = "Seoul, Republic of Korea",
    series = "HCIK '15"
}

