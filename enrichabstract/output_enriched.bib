@incollection{thenonverbalcommunication2024_107,
  title = {The Nonverbal Communication of Biological Sex and Gender},
  author = {Terrence and Horgan},
  year = {2024},
  journal = {The Nonverbal Communication of Our Gendered and Sexual Selves},
  doi = {10.1007/978-3-031-54361-6_2},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-54361-6_2},
  item_title = {The Nonverbal Communication of Biological Sex and Gender},
  publication_title = {The Nonverbal Communication of Our Gendered and Sexual Selves},
  item_doi = {10.1007/978-3-031-54361-6_2},
  authors = {Terrence G. Horgan},
  publication_year = {2024},
  content_type = {Chapter},
  abstract = {In this chapter, the relations between biological sex/gender and nonverbal cues, behaviors, and abilities are discussed. First, the variability that exists within the two biological sex categories (viz., female, male) is covered, followed by a review of sex differences in nonverbal cues and behaviors (Quadrants 1 and 4). Next, caveats pertaining to the interpretation of gender differences are enumerated before observed differences between men’s and women’s nonverbal behavior are reviewed (cues/behaviors displayed; nonverbal skills). Afterward, the debate about the origin of differences in the nonverbal skills and behaviors of females/women and males/men is outlined. In the world of artificial intelligence, questions about the future relevance of debates concerning the origin of gender differences in nonverbal communication close the chapter.}
}


