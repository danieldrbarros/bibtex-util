@inproceedings{designingoflearningenviro2022_97,
  title = {Designing of Learning Environment of an Intelligent Tutoring System for Academic Learning Needs of Learning-Disabled Learners Based on Survey Report of Region-Specific Target Group},
  author = {Neelu Jyothi Ahuja and Monika Thapliyal and Anand Nayyar and Adarsh Kumar},
  year = {2022},
  journal = {Emerging Technologies for Computing, Communication and Smart Cities},
  doi = {10.1007/978-981-19-0284-0_29},
  url = {https://link.springer.com/chapter/10.1007/978-981-19-0284-0_29},
  item_title = {Designing of Learning Environment of an Intelligent Tutoring System for Academic Learning Needs of Learning-Disabled Learners Based on Survey Report of Region-Specific Target Group},
  publication_title = {Emerging Technologies for Computing, Communication and Smart Cities},
  item_doi = {10.1007/978-981-19-0284-0_29},
  authors = {Neelu Jyothi AhujaMonika ThapliyalAnand NayyarAdarsh Kumar},
  publication_year = {2022},
  content_type = {Conference paper},
  abstract = {The twenty-first century is known for exponential growth in the technological as well as the education domain. However, conventional educational tools are still reliable to understand the actual scenario of performance and efficiency of the brain of young minds. If combined with technology this could play a vital role in getting a clear perception about what they feel and how they improve the educational methodology. Studies on dyslexia, dysgraphia and dyscalculia have shown that it is very tough and sometimes impossible to identify these learners without the help of professionals. Unlike physical challenges, the challenges from these disabilities are not measurable in quantified terms. For this, perception-based studies play a vital role. There are various studies, which suggest questionnaire-based survey, or direct interviews with the target group are a more reliable source of information. Also, regional-level data sometimes plays an important role to understand geographical and environmental impacts on the target group. Various reports were studied to understand the similarities. Authors collected information as a pilot project through a survey on 292 learners (learning-disabled and non-learning-disabled) in different institutes. 142 of them were dealing with single or multiple learning disabilities. Study helped in identifying the most affected learning domains and related multiple-criteria affecting the learners. This eventually is implemented in the domain model of an intelligent tutoring system to develop the four learner-centric learning environments. Results show that practice-based learning environment was the most relatable learning environment followed by visual-based learning environment.}
}


@incollection{inclusivevirtualrealityle2024_98,
  title = {Inclusive Virtual Reality Learning Environment},
  author = {Astra and Linda Daniela and Zinta and Supe},
  year = {2024},
  journal = {Applied Assistive Technologies and Informatics for Students with Disabilities},
  doi = {10.1007/978-981-97-0914-4_11},
  url = {https://link.springer.com/chapter/10.1007/978-981-97-0914-4_11},
  item_title = {Inclusive Virtual Reality Learning Environment},
  publication_title = {Applied Assistive Technologies and Informatics for Students with Disabilities},
  item_doi = {10.1007/978-981-97-0914-4_11},
  authors = {Astra RūdolfaLinda DanielaZinta Zālīte-Supe},
  publication_year = {2024},
  content_type = {Chapter},
  abstract = {With the rapid development of virtual reality (hereafter VR), the possibilities for students with all kinds of disabilities bring new opportunities as well as have become an attractive research topic. VR and the possibilities of creating a learning environment in it raise inclusive education to a new, hitherto unprecedented level. Numerous studies have shown that VR may provide new opportunities for learning designs in school settings or professional training. However, there is a limited number of reviews examining the role and research focus of exploring the impact of VR on inclusive education and educational VR experiences for students with disabilities. The main focus of this literature review is on examining the use of VR for enhancing accessibility, and engagement, as well as an understanding of educational content and learning outcomes across inclusive education. To summarize, this study makes several recommendations for inclusive VR learning environment developers and educators, researchers, and policymakers in higher education settings as a reference based on the results. It is essential to conduct rigorous research in education to better understand the potential benefits, challenges, and limitations of VR for individuals with disabilities and to inform the development of inclusive and effective VR applications and interventions in the future.}
}


@incollection{academicchallengesofpupil2023_99,
  title = {Academic Challenges of Pupils with Disabilities and Effective Inclusive Practices},
  author = {Erez and Miller and Efrat Kass},
  year = {2023},
  journal = {Self-Efficacy and Success: Narratives of Adults with Disabilities},
  doi = {10.1007/978-3-031-14965-8_7},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-14965-8_7},
  item_title = {Academic Challenges of Pupils with Disabilities and Effective Inclusive Practices},
  publication_title = {Self-Efficacy and Success: Narratives of Adults with Disabilities},
  item_doi = {10.1007/978-3-031-14965-8_7},
  authors = {Erez C. MillerEfrat Kass},
  publication_year = {2023},
  content_type = {Chapter},
  abstract = {This chapter discusses the academic challenges and effective inclusive practices for pupils with several types of childhood disabilities, such as learning disabilities, attention-deficit hyperactivity disorder (ADHD), and autistic spectrum disorders. We discuss the needs and accommodations these pupils require, as they have very different needs. Moreover, we discuss the implications and consequences of misdiagnosis or an accurate but delayed diagnosis on the academic development of these pupils. We then present current and future trends in inclusive education for pupils with disabilities. The chapter concludes with some practical recommendations for educational teams who work with pupils with disabilities.}
}


@article{learninganalyticsinseriou2024_100,
  title = {Learning Analytics in Serious Games as Predictors of Linguistic Competence in Students at Risk},
  author = {Susana and Castro and Pascual Sevillano and Javier Fombona Cadavieco},
  year = {2024},
  journal = {Technology, Knowledge and Learning},
  doi = {10.1007/s10758-024-09726-5},
  url = {https://link.springer.com/article/10.1007/s10758-024-09726-5},
  item_title = {Learning Analytics in Serious Games as Predictors of Linguistic Competence in Students at Risk},
  publication_title = {Technology, Knowledge and Learning},
  item_doi = {10.1007/s10758-024-09726-5},
  authors = {Susana Sánchez CastroMª Ángeles Pascual SevillanoJavier Fombona Cadavieco},
  publication_year = {2024},
  content_type = {Article}
,
  abstract = {The planned systematized design of the use of serious games in the classroom is presented as a strategy to optimize learning. In this framework, Learning Analytics represents stealth assessment and follow-up method, and a way to personalize such games by simplifying their application for teachers. The aim of this research was to analyze the impact of the use of serious games on improving linguistic competence in socio-educationally disadvantaged students, with a proposal for a planned systematized intervention. We use two specific games to improve linguistic competence and its learning analytics to achieve the proposed goal. This study carried out was pre-experimental, with pretest and posttest, and the sample consisted of 75 students at 4 primary education centers in Spain (36 boys, 39 girls) aged 9–12 (M = 10.6; SD = 0.7) at risk due to socioeconomic conditions in Primary Education. The results show that (a) the serious games integrated into the curriculum and adjusted to the learning objectives can facilitate the development and acquisition of linguistic competence in students with socio-educational disadvantages; (b) these students can match their peers in performance and competencies with appropriate systematic intervention; (c) the level acquired in a key competence can be evaluated and specific needs identified in students with academic difficulties using learning analytics; (d) learning analytics can contribute to predicting student performance in academic subjects through the scores collected in the analysis of learning integrated into serious games. These findings contribute to filling research gaps in these four aspects.}
}

@incollection{hitchingaridewithstevegra2023_101,
  title = {Hitching a Ride with Steve Graham Through the Galaxy of Writing Research},
  author = {Tanya Santangelo and Michael Hebert and Pamela Shanahan Bazis},
  year = {2023},
  journal = {The Hitchhiker's Guide to Writing Research},
  doi = {10.1007/978-3-031-36472-3_21},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-36472-3_21},
  item_title = {Hitching a Ride with Steve Graham Through the Galaxy of Writing Research},
  publication_title = {The Hitchhiker's Guide to Writing Research},
  item_doi = {10.1007/978-3-031-36472-3_21},
  authors = {Tanya SantangeloMichael HebertPamela Shanahan Bazis},
  publication_year = {2023},
  content_type = {Chapter},
  abstract = {Steve Graham’s legacy as a writing researcher may be best represented through his systematic reviews and meta-analyses. Through his reviews, he has hitchhiked through the literature and provided the field with a guide to the galaxy of writing research. The purpose of this chapter was to review Graham’s systematic reviews and place them within the context of a scoping review of all of the other systematic reviews of writing research. To do this, we conducted two separate reviews. First, we identified all of the reviews of writing research on Steve Graham’s curriculum vitae and grouped and reviewed them by type. Second, we conducted a scoping review of the writing research. We identified a total of 317 systematic reviews of the writing literature, of which 40 (13%) involved Steve Graham as an author. Of the 277 reviews that did not include Steve Graham as an author, 117 (42%) cited Graham at-least once. Graham’s reviews have spanned 44 years (and counting) and included more than 2900 studies. We classified Graham’s reviews into three primary types: (1) instructional effectiveness, (2) group comparisons, and (3) general non-systematic reviews. Some of the major findings of Graham work include (a) the identification of more than 30 effective general practices for improving writing outcomes for students, (b) writing and writing instruction improve reading and content learning, (c) students who are at-risk for learning difficulties due to reading, language, or ADHD also tend to perform lower than their typically developing peers in writing, and (d) some of his general reviews of the literature show a more complete picture of the writing literature in a particular area. The discussion includes ideas for how Graham’s work might be used to inform future writing research.}
}


@incollection{whyperspectivepozeamultid2024_102,
  title = {WHY: Perspective: POZE—A Multidisciplinary Framework of Life},
  author = {Cornelia and Walther},
  year = {2024},
  journal = {Human Leadership for Humane Technology},
  doi = {10.1007/978-3-031-67823-3_1},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-67823-3_1},
  item_title = {WHY: Perspective: POZE—A Multidisciplinary Framework of Life},
  publication_title = {Human Leadership for Humane Technology},
  item_doi = {10.1007/978-3-031-67823-3_1},
  authors = {Cornelia C. Walther},
  publication_year = {2024},
  content_type = {Chapter},
  abstract = {This foundational chapter introduces the multidisciplinary POZE framework to analyze the interplay of humans and technology. The m4-matrix is offered to map out the arenas where transformative changes are occurring at the intersection of individual (aspiration, emotions, thoughts, sensations) and societal (individual, community, country, planet) dimensions. The argument is made that a mindset of agency amid AI, across generations, cultures, and socioeconomic backgrounds can transform technology into an ally for humankind. The A-Frame is introduced to cultivate such agency intentionally, which involves awareness of interplays and appreciation of individual vulnerability, requiring acceptance of the unique opportunity that humans have to create the reality they want, and accountability for the responsibility that comes with that privilege. Combined these attitudes result in the type of leadership mindset that is needed to promote and achieve agency amid AI. As it will be explained, leadership should be approached as a way of life, independent of hierarchy; perceived as a path that is driven by values. If it is framed in such a manner it opens a path for anyone to rise beyond personal interest to the bigger picture perspective of the Common Good, which is a pragmatic perspective considering the interconnected nature of everything. We look at the Spiral of influence which allows humans to trigger change, and the potential of technology to support them. Everyone can win if everyone has a fair chance to play; this book shows possible ways to achieve this. The binomen of GIGO (Garbage in, Garbage out) versus VIVO (Values in, Values out) is introduced as the central tension of the relationship that humans entertain with technology; it reflects the argument that humans cannot expect the technology of tomorrow to reflect values that they do not manifest today.}
}


@incollection{beyondcommonusesthepowera2025_103,
  title = {Beyond common uses: the power and utility of chatbots},
  author = {Adrian Wallwork},
  year = {2025},
  journal = {The Pros and Cons of Using Chatbots},
  doi = {10.1007/978-3-032-00179-5_4},
  url = {https://link.springer.com/chapter/10.1007/978-3-032-00179-5_4},
  item_title = {Beyond common uses: the power and utility of chatbots},
  publication_title = {The Pros and Cons of Using Chatbots},
  item_doi = {10.1007/978-3-032-00179-5_4},
  authors = {Adrian Wallwork},
  publication_year = {2025},
  content_type = {Chapter},
  abstract = {Chatbots can do far more than proofread or summarize. This chapter dives into six creative applications, from designing dynamic presentations to simulating peer reviews. Discover how chatbots can analyze your spoken and written communication for tone and clarity, or help you craft better AI prompts for precise results. Experiment with techniques like “bot debates” to test arguments or preemptively address feedback. These unconventional uses will expand how you think about—and use—AI in your work.}
}


@article{twentyfiveyearsoftheeduca2022_104,
  title = {Twenty-five years of the Education and the Information Technologies journal: Past and future},
  author = {Arthur Tatnall and Andrew Fluck},
  year = {2022},
  journal = {Education and Information Technologies},
  doi = {10.1007/s10639-022-10917-9},
  url = {https://link.springer.com/article/10.1007/s10639-022-10917-9},
  item_title = {Twenty-five years of the Education and the Information Technologies journal: Past and future},
  publication_title = {Education and Information Technologies},
  item_doi = {10.1007/s10639-022-10917-9},
  authors = {Arthur TatnallAndrew Fluck},
  publication_year = {2022},
  content_type = {Article}
,
  abstract = {This article examines how research publications in education and information technologies have changed over the last twenty-five years. The authors investigate articles published in the journal: Education and Information Technologies (EAIT). To celebrate a quarter-century of this publication. They take a retrospective view of the EAIT journal, using Historical Research methodology to show some of the trends in topics covered and to interrogate the expanding cultural background of published authors. While computer technology has developed rapidly over this time, research methodologies, international collaborations, and discipline areas have multiplied quickly. Finally, this article identifies some unique papers that have appeared in print and provides glimpses into what the future may hold.}
}

@article{howelementaryschoolteache2025_105,
  title = {How elementary school teachers use writing to support reading in the science of reading era: A national survey},
  author = {Michael Hebert and Allison and High and Julia and Flanigan},
  year = {2025},
  journal = {Reading and Writing},
  doi = {10.1007/s11145-025-10723-y},
  url = {https://link.springer.com/article/10.1007/s11145-025-10723-y},
  item_title = {How elementary school teachers use writing to support reading in the science of reading era: A national survey},
  publication_title = {Reading and Writing},
  item_doi = {10.1007/s11145-025-10723-y},
  authors = {Michael HebertAllison E. HighJulia R. Flanigan},
  publication_year = {2025},
  content_type = {Article}
,
  abstract = {The science of reading movement has had a strong influence on teaching and research in the last 7–10 years, although writing has received less attention in the movement Graham (2020). This survey of 187 general and 188 special education elementary teachers was conducted to examine their use of writing to support reading, with return rates of 22.9% and 25.3%, respectively. The survey has a conservative margin of error of rate of +/− 7% (which reduced to +/− 5% for many items). Both samples responded to identical questions about their writing to read practices, beliefs, self-efficacy, and training. Results indicated large proportions of teachers (84% of general education and 77% special education) believed writing is effective for improving reading and used many effective practices. However, substantial proportions of teachers reported being uncertain or disagreeing that writing is effective for improving reading, used practices less frequently, and believe the practices to be less effective with younger and low-achieving writers. Regression models showed that special education teachers reported using fewer practices than general education teachers ( p = .026), although there was no statistically significant difference in the frequency of their use of writing to read practices ( p = .423). Teachers’ beliefs were statistically significant predictors of their use of the practices. Recommendations center on emphasizing writing within the science of reading movement, identifying areas for future research.}
}

