@article{WOS:001586564500001,
  author                     = {Yu, Xiaoxuan and Ishiwata, Tanni and Zhang, Xiaobo and Zhang, Dandan and
                                Xu, Lijun and Su, Yi and Sha, Xiaocao},
  title                      = {`More than just music': a multimodal intervention supporting adolescents
                                with autism spectrum disorder in a community-based program in Shanghai},
  journal                    = {INTERNATIONAL JOURNAL OF DEVELOPMENTAL DISABILITIES},
  year                       = {2025},
  month                      = {2025 SEP 18},
  abstract                   = {Objectives Autism Spectrum Disorder (ASD) affects communication, social
                                interaction, and emotional expression, requiring multifaceted
                                interventions. While Music Therapy (MT) is widely applied, its
                                integration with structured education, real-life social practice, and
                                technology-assisted methods may further enhance its effectiveness. This
                                study evaluates the MT Plus (MT+) model developed by the Shanghai Angel
                                Autism Salon (SAAS), which integrates traditional MT with structured
                                academic instruction (LOVE CLASSROOM), vocational social training
                                (A-COFFEE), and AI-assisted digital art to support adolescents with ASD.
                                Methods Fifty-two adolescents with ASD participated in this
                                intervention. Pre- and post-intervention outcomes were assessed using
                                the Autism Behavior Checklist (ABC) and Parenting Stress Index-Short
                                Form (PSI-SF). Independent t-tests and regression analyses were
                                conducted to evaluated changes. Results Significant improvements were
                                observed in sensory processing, social interaction, motor skills,
                                language, and self-care (Cohen's d: 1.52-2.26), with the most
                                substantial gain in self-care (88.42\%). Parental stress and
                                dysfunctional interactions decreased, particularly in child
                                manageability (50.54\%). AI-assisted components enhanced sensory
                                outcomes (p = 0.005), and participation in A-COFFEE led to notable
                                development in language skills (p = 0.040). Better child behavior was
                                associated with lower parental stress (R-2 = 0.325, p < 0.0001).
                                Conclusions The MT+ model presents a holistic, community-based approach
                                to improving outcomes for adolescents with ASD. Further research using
                                randomized controlled trials is recommended. These findings suggest that
                                the MT+ intervention may offer a promising community-based model for
                                enhancing social communication, emotional regulation, and adaptive
                                functioning in adolescents with autism.},
  publisher                  = {TAYLOR \& FRANCIS LTD},
  address                    = {2-4 PARK SQUARE, MILTON PARK, ABINGDON OR14 4RN, OXON, ENGLAND},
  type                       = {Article; Early Access},
  language                   = {English},
  affiliation                = {Sha, XC (Corresponding Author), Shanghai Univ, Sch Mus, Shanghai, Peoples R China.
                                Yu, Xiaoxuan; Zhang, Xiaobo; Zhang, Dandan; Xu, Lijun; Su, Yi, Shanghai Jiao Tong Univ, Sch Med, Shanghai, Peoples R China.
                                Ishiwata, Tanni, Shanghai Caopeng Char Fdn, Shanghai, Peoples R China.
                                Zhang, Dandan, Shanghai Conservatory Mus, Shanghai, Peoples R China.
                                Sha, Xiaocao, Shanghai Univ, Sch Mus, Shanghai, Peoples R China.},
  doi                        = {10.1080/20473869.2025.2561160},
  earlyaccessdate            = {SEP 2025},
  issn                       = {2047-3869},
  eissn                      = {2047-3877},
  keywords                   = {Autism spectrum disorder; MT plus model; social practice; multimodal
                                intervention; adolescent rehabilitation},
  keywords-plus              = {CHILDREN; THERAPY; PERCEPTION; BEHAVIORS; PARENTS; IMPACT},
  research-areas             = {Education \& Educational Research; Rehabilitation},
  web-of-science-categories  = {Education, Special; Rehabilitation},
  author-email               = {shaviolin@126.com},
  affiliations               = {Shanghai Jiao Tong University; Shanghai Conservatory of Music; Shanghai
                                University},
  researcherid-numbers       = {Yu, Xiaoxuan/LEL-8800-2024},
  funding-acknowledgement    = {Medical Education Research Project of Chinese Medical Association},
  funding-text               = {The authors extend their sincere gratitude to the SAAS, its dedicated
                                volunteers, and the participating families for their wholehearted
                                support and commitment to this study. We also appreciate the
                                contributions of the Shanghai City Symphony Orchestra for their guidance
                                in structured music training and ensemble performances. Special thanks
                                to the educators and therapists involved in the LOVE CLASSROOM and
                                A-COFFEE programs for their dedication to structured learning and social
                                training. Additionally, we acknowledge the assistance of researchers and
                                data analysts in statistical evaluation, as well as AI specialists for
                                their contributions to the development of the AI-assisted intervention
                                module. Lastly, we thank the parents and caregivers for their kindness
                                and cooperation, which were essential to the success of this study.},
