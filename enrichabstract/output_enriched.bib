@incollection{multitaskingtraining2022_154,
  title = {Multitasking Training},
  author = {Julia Karbach and Tilo Strobach},
  year = {2022},
  journal = {Handbook of Human Multitasking},
  doi = {10.1007/978-3-031-04760-2_8},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-04760-2_8},
  item_title = {Multitasking Training},
  publication_title = {Handbook of Human Multitasking},
  item_doi = {10.1007/978-3-031-04760-2_8},
  authors = {Julia KarbachTilo Strobach},
  publication_year = {2022},
  content_type = {Chapter},
  abstract = {Multitasking is considered a key aspect of executive control functioning. It refers to the ability to perform two tasks at the same time or to flexibly switch between them. The last two decades have seen an immense increase in the scientific interest in studies designed to improve multitasking and to assess whether improvements of cognitive multitasking training can be transferred to untrained tasks. The interest in this area of research has been fueled by basic science interested in the cognitive and neural mechanisms underlying the effects, but also by applied science focusing on the design of interventions in the clinical and educational context. While it is undisputed that multitasking trainings lead to large, long-lasting performance gains and usually to performance improvements in untrained, similar tasks, transfer to other cognitive abilities and activities of daily life is intensely debated. In this chapter, we will review existing evidence by introducing the concept of cognitive plasticity and methodological approaches to study multitasking training. We will then summarize theoretical frameworks for transfer of training and review current findings on task-switching training and dual-task training, followed by a section on the importance of analyzing individual differences and age differences in multitasking training gains and the application of multitasking training. We close by summarizing the most important findings and highlighting important new directions for the field of multitasking training research.}
}


@article{enduseradaptabletechnolog2020_155,
  title = {End-user adaptable technologies for rehabilitation: a systematic literature review},
  author = {Jessica and Palomares and Pecho and Greis Francy and Silva and Calpa and Alberto and Raposo},
  year = {2020},
  journal = {Universal Access in the Information Society},
  doi = {10.1007/s10209-020-00720-z},
  url = {https://link.springer.com/article/10.1007/s10209-020-00720-z},
  item_title = {End-user adaptable technologies for rehabilitation: a systematic literature review},
  publication_title = {Universal Access in the Information Society},
  item_doi = {10.1007/s10209-020-00720-z},
  authors = {Jessica M. Palomares-PechoGreis Francy M. Silva-CalpaAlberto B. Raposo},
  publication_year = {2020},
  content_type = {Article},
  abstract = {Studies on end-user adaptable applications for rehabilitation aim to offer exercises to patients based on their therapeutic goals and individual advances. The process of adapting the applications is usually done by therapists, who have the clinical knowledge necessary for the effective design of the exercises; thus, their participation is essential in this process. In this sense, it is crucial that studies on adaptable applications consider their relevance for various users: patients who use an application (potential end users) and therapists who perform the process of adapting the application (end users). This study aims, through a systematic review, to identify how the use of adaptable applications has contributed, in the context of rehabilitation, not only to the treatment of patients but also to therapists in their work, in addition to identifying how they have addressed the process of adaptation and extension of the applications. A total of 28 studies from four electronic databases were considered and analyzed. The results indicate promising benefits for patients and some benefits that support the therapist’s work. However, there are some difficulties faced by therapists in the use and adoption of the applications. Further studies on the impact of adaptable applications in view of the end users (therapists adapting the applications) are needed. A longer-term follow-up is required to evaluate the treatment outcomes in the patients and improve the required aspects according to therapeutic contexts.}
}


@article{proceedingsofacbicon20222022_156,
  title = {Proceedings of ACBICON 2022},
  year = {2022},
  journal = {Indian Journal of Clinical Biochemistry},
  doi = {10.1007/s12291-022-01106-z},
  url = {https://link.springer.com/article/10.1007/s12291-022-01106-z},
  item_title = {Proceedings of ACBICON 2022},
  publication_title = {Indian Journal of Clinical Biochemistry},
  item_doi = {10.1007/s12291-022-01106-z},
  publication_year = {2022},
  content_type = {Article}
,
  abstract = {E-teaching/leaming methods have replaced classroom teaching during COVID-19 pandemic. Medical Teachers are the key stakeholders of medical education and their perception to ETL and their attitude towards it has a significant impact on education. Aim was toAssess the attitude and perception of medical teachers of SHKM, GMC, Mewat, Haryana towards ETL. This was a cross-sectional, questionnaire-based survey from 50 medical faculty members. Scoring was done according to five point Likert scale. 68%faculty was not happy about student teacher interaction,82%felt students are more attentive in classroom;were not motivated during online lectures;82%responded that students are more disciplined during classroom lectures.92%Faculty had sufficient computer knowledge and IT skills to conduct lectures,80%stated they could have flexible hours, 60%faced technical difficulties, 78%got difficulty conducting practical /clinical teaching;50%experienced ETL reduces the power of teacher in front of students;77%responded ETL reduces the skills of students in learning;68%felt would not help students in writing exams better;84%faculty agreed that they should have ETL training;84% felt ETL has limited application in medical education;78%felt ETL would slow down the curriculum;94%responded classroom lectures should not be replaced by online teaching but can be used as a supplementary tool especially during the emergency. Concluded thatETL can be an aid during an emergency such and blended learning is more acceptable. There is need to develop and implement innovative solutions in response to this present demand of use of technology to prepare for future. Training for medical teachers is required in regard to newer teaching learning technologies.}
}

