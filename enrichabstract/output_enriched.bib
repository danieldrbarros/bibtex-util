@incollection{usingmultimediatechnologi2015_217,
  title = {Using Multimedia Technologies to Support Culturally and Linguistically Diverse Learners and Young Children with Disabilities},
  author = {Kavita Rao and James Skouge},
  year = {2015},
  journal = {Young Children and Families in the Information Age},
  doi = {10.1007/978-94-017-9184-7_6},
  url = {https://link.springer.com/chapter/10.1007/978-94-017-9184-7_6},
  item_title = {Using Multimedia Technologies to Support Culturally and Linguistically Diverse Learners and Young Children with Disabilities},
  publication_title = {Young Children and Families in the Information Age},
  item_doi = {10.1007/978-94-017-9184-7_6},
  authors = {Kavita RaoJames Skouge},
  publication_year = {2015},
  content_type = {Chapter},
  abstract = {Multimedia technologies can be used creatively to provide opportunities for children to practice skills and become producers of knowledge. In this chapter, we describe ways in which multimedia software can be used to support culturally and linguistically diverse students as well as young children with developmental delays or disabilities. The projects we describe are aligned with Universal Design for Learning (UDL) principles and best practices for culturally-responsive education. Using commonly-available productivity tools on computers and mobile devices, teachers and parents can create photo and video-based projects that give students the opportunity to practice communication, social, and behavior skills. We emphasize ways to honor the diverse cultural backgrounds of students and to foster first language literacy along with acquisition of language skills.}
}


