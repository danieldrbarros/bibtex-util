},

abstract = {Objective: Open Access (OA) publishing is a global movement that may increase access to clinical trial results to the healthcare providers and patients. To assess the percentage of manuscripts published OA over an 8 year period (2010–2018) and the impact of OA on reach.

Research design and methods: OA publications were defined as any Creative Commons (CC) license that allowed the consumer to read for free. Digital object identifiers (DOIs) for 3321 Company-sponsored manuscripts from January 1, 2010 to June 30, 2018 were entered into Unpaywall.org, which returned license information. Trends in OA licenses over time were assessed. For 390 publications (2017–2018) with mentions (Altmetric.com) and impact factor (IF), we compared the reach of articles published in OA and non-OA journals, IF, and when OA journals were selected (1st, 2nd, or later journal submission).

Results: Unpaywall results for 3321 published articles demonstrated CC licenses increased ∼3-fold (14–41%) over 8 years. Reach or total mentions varied widely (0–1016) across 390 publications in journals with IF ranging from 0–54.42. Only 3/83 OA publications were in journals with IF above the median (3.7). Median mentions for articles in OA journals were similar (16) to those in non-OA journals (13). For primary manuscripts submissions in 2017 through June 30, 2018, OA journals were selected as the first-choice journal for 13% (5/38).

Conclusions: The uptake in OA observed over time is likely due to increased awareness, funding, and availability of OA. Although in this sample median reach was similar for OA vs no-OA publications, OA is not yet frequently selected as an initial choice for primary papers.}

}


@article{Carroll21042026,
author = {Fiona Carroll and Shahab G. Dastjerd},
title = {Digital literacy as a modern necessity: Insights from developing an inclusive digital culture in Welsh communities},
journal = {Community Development},
volume = {0},
number = {0},
pages = {1--19},
year = {2026},
publisher = {Routledge},
doi = {10.1080/15575330.2026.2661176},


URL = { 
    
        https://doi.org/10.1080/15575330.2026.2661176
    
    

},
eprint = { 
    
        https://doi.org/10.1080/15575330.2026.2661176
    
    

},

abstract = {Traditional literacy and numeracy are no longer sufficient; people must also develop strong digital literacy skills. However, access to digital learning is often constrained by local infrastructure, support and resources, placing many individuals at risk of digital exclusion. This paper argues that fostering digitally inclusive communities is essential for developing widespread digital confidence. It draws on empirical evidence from digital skills workshops in Wales (UK) which employed a mixed-methods approach to analyse educators’ and learners’ experiences. The findings highlight the importance of embedding learning within familiar community contexts, employing flexible and scaffolded pedagogies, and tailoring programs to address local demographic disparities. Moreover, the paper emphasises the importance of integrating top-down strategies in education, leadership, collaboration, and engagement with bottom-up approaches to establish digital literacy as a foundational priority. In conclusion, the paper provides evidence-informed recommendations to nurture a digitally inclusive culture in our communities and to enhance individual digital confidence.}

}


@article{Berthier02012026,
author = {Marcelo L. Berthier and Alejandro Sosa-Welford and Juan Rafael Orozco-Arroyave and Diana López-Barroso and María José Torres-Prioris and Guadalupe Dávila and Adolfo M. García},
title = {Speech and language outcome measures in clinical trials of Alzheimer’s and Parkinson’s diseases},
journal = {Expert Review of Neurotherapeutics},
volume = {26},
