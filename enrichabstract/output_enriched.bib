  item_doi = {10.1007/978-3-030-40237-2_3},
  authors = {Uttama Lahiri},
  publication_year = {2020},
  content_type = {Chapter},
  abstract = {Conventional observation-based intervention, though powerful, it might pose limitations given restricted availability of adequately trained resources, high cost of intervention, etc. Thus, researchers had been exploring the use of alternate technology-assisted intervention techniques that can serve as a complementary tool in the hands of the clinician, offer quantitative estimates, etc. In this chapter, I introduce the reader to the various types of technology-assisted intervention techniques, such as Robot-assisted and Computer-assisted techniques along with various applications for skill training of individuals with autism.}
}


@incollection{genreandtaskspecificfeatu2022_144,
