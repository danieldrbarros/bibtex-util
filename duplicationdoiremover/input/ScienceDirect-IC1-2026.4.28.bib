  url      = {https://www.sciencedirect.com/science/article/pii/S2405844024109255},
  author   = {Ni Yao and Qiong Wang},
  abstract = {This article has been retracted: please see Elsevier policy on article withdrawal (https://www.elsevier.com/about/policies-and-standards/article-withdrawal). This article has been retracted at the request of the Editor-in-Chief. Post-publication, a journal wide investigation conducted by the journal Editors in collaboration with Elsevier's Research Integrity & Publishing Ethics team could not confirm ethical approval was given for the research presented in this publication in line with the journal's policy. Additionally, the investigating Editor identified references that are irrelevant to the article. The authors were asked to comment upon the presence of these references in their work but were unable to satisfactorily address the reason for the references. Consequently, the Editor no longer has confidence in the integrity and the findings of the article and has decided to retract it. The scientific community takes a very strong view on this matter and apologies are offered to readers of the journal that this was not detected during the submission process.}
}
@incollection{KUMAR202667,
  title     = {Chapter 4 - Toward emotionally intelligent interfaces: An HCI approach to cognitive and learning support},
  editor    = {Shubham Mahajan and Divneet Singh Kapoor and Kiran Jot Singh},
  booktitle = {Intelligent Systems for Neurocognition and Human-Robot-Computer Interaction},
  publisher = {Academic Press},
  pages     = {67-92},
  year      = {2026},
  isbn      = {978-0-443-41660-6},
  doi       = {https://doi.org/10.1016/B978-0-443-41660-6.00015-6},
  url       = {https://www.sciencedirect.com/science/article/pii/B9780443416606000156},
  author    = {Prabhat Kumar and Arie Kurnianto and Nitin Sahai},
  keywords  = {Artificial intelligence, Augmented reality, Brain–computer interfaces, Human–Computer interaction, Machine learning, Virtual reality},
  abstract  = {Human–computer interaction (HCI) is transforming cognitive, emotional, and learning wellness with intelligent systems. This chapter will address the neurocognitive bases, focus on elements such as attention, perception, memory, and adaptive cognition, and explain how these concepts can be applied to human–technological interaction. Cognitive wellness is enhanced through intelligent systems using artificial intelligence (AI), brain–computer interfaces, and immersive technologies such as virtual and augmented reality. These intelligent solutions can support cognitive rehabilitation, mental health interventions, and provide personalized adaptive experiences. Emotional well-being is supported through affective computing (our ability to assess affect through technologies), emotion recognition, and empathetic social robotics. These types of intelligent systems will be designed so that they detect and respond to the human emotional experience, while also ethically managing privacy disclosure. In the educational space, artificial intelligent systems that support personalized learning, neuro-adaptive environments, and serious games will facilitate the development of skills and continuous learning. The role of HCI in cognitive reserve, adaptive educational systems, practical applications of serious games, and education can contribute to educational and social well-being as we age. The healthcare space opens the door for HCI to support mental health interventions informed by AI, assistive technologies, and robotics for aging in place. While there are tremendous applications for HCI to elicit and elevate human well-being, there are ethical considerations related to data security, biases of AI, and enduring engagement in intelligent systems. Discussion will include future trends of neuromorphic computing, human–robot symbiosis, and quantum computing for HCI that take human well-being into consideration.}
}
@article{TUSHARUMRANI2022103699,
  title    = {Hybrid feature-based anxiety detection in autism using hybrid optimization tuned artificial neural network},
  journal  = {Biomedical Signal Processing and Control},
  volume   = {76},
  pages    = {103699},
  year     = {2022},
  issn     = {1746-8094},
  doi      = {https://doi.org/10.1016/j.bspc.2022.103699},
  url      = {https://www.sciencedirect.com/science/article/pii/S174680942200221X},
  author   = {Amruta {Tushar Umrani} and Pon Harshavardhanan},
  keywords = {Anxiety detection, Artificial neural network, Optimization, EEG signals, Autism disorders},
  abstract = {Autism is a neurobehavioral disorder that negatively influences the social and communication skills of the individual. Autism is also known as an autism spectrum disorder (ASD) due to its various types of symptoms. The anxiety among the normal person concerns the physician especially, for the ASD person as it creates negative impacts on psychological and physical health. Hence, a dynamic anxiety detection model is developed in this research with the support of an optimized Artificial Neural Network (ANN). Initially, the input EEG signal from the database is pre-processed for the removal of noise and artifacts of the signal using the bandpass filter (BPF) and then the significant features are extracted for the reduction of the complexity. Then, the ANN is utilized for the detection of the anxiety, which is trained using the proposed Trace and Forage optimization (TF) algorithm that is designed through the combination of the characteristics of the rescue search agents and the Finches to obtain the enhanced ability of detection. The analysis is done band-wise using the two standard databases such as DEAP and SEED datasets in terms of metrics, such as specificity, sensitivity, and accuracy. The proposed anxiety detection model achieves an accuracy of 96.67 % with the help of DEAP in accordance with the training percentage.}
}
@article{KAUTS2025202625,
  title    = {Digital interventions for enhancing communication and collaboration in children with autism spectrum disorder: An integrative review},
  journal  = {Research in Autism},
  volume   = {125},
  pages    = {202625},
  year     = {2025},
  issn     = {3050-6565},
  doi      = {https://doi.org/10.1016/j.reia.2025.202625},
  url      = {https://www.sciencedirect.com/science/article/pii/S3050656525000975},
  author   = {Deepa Sikand Kauts and Moomin Ahmad Rather},
  keywords = {Autism Spectrum Disorder, Digital interventions, Communication, Collaboration Mobile apps, Virtual reality, Robot-assisted therapy},
  abstract = {Background
              Children with Autism Spectrum Disorder (ASD) often experience significant challenges in communication and collaboration. Traditional interventions, though beneficial, may require substantial resources and may not always accommodate the diverse sensory and cognitive needs of children with ASD. Digital interventions, including mobile applications, virtual reality (VR), and robot-assisted therapy, provide flexible and engaging alternatives by utilizing structured, interactive, and visually enriched environments tailored to the strengths of children with ASD.
              Method
              This integrative review, conducted following PRISMA guidelines, analyzed studies published between 2011 and 2022 to explore how various digital interventions support communication and collaboration skills in children with ASD. Eleven studies that met the inclusion criteria were selected from databases such as Google Scholar, ERIC, and PsycINFO. A qualitative synthesis of findings was performed, considering study methodologies, target skills, and reported outcomes.
              Results
              Findings suggest that mobile applications, particularly those incorporating speech-generating devices, facilitate verbal communication in younger children. Robot-assisted therapy has shown potential in enhancing nonverbal communication, such as eye contact and gestures, while VR and game-based learning promote collaborative behaviors like turn-taking and joint problem-solving. Although some studies reported effect sizes (e.g., Cohen’s d = 0.32 [0.12–0.51]), the heterogeneity in study designs and intervention types limits direct comparisons. Instead, trends across studies indicate promising advancements in digital support for social and communication development in children with ASD.
              Conclusion
              Digital interventions offer valuable opportunities for enhancing social and communication skills in children with ASD. While these tools complement traditional therapeutic approaches, variability in intervention designs and sample sizes suggests the need for further research to refine their implementation in educational and clinical settings.}
}
