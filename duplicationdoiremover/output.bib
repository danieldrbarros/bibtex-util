}

@inproceedings{10580412,
    author = "Swapna, Pasam and Nanthini, S.",
    booktitle = "2024 5th International Conference on Innovative Trends in Information Technology (ICITIIT)",
    title = "Autism Traits Detection in Toddlers: Enhanced Random Forest vs. Support Vector Machine",
    year = "2024",
    volume = "",
    number = "",
    pages = "1-5",
    abstract = "The aim of this study is to use behavioral indicators to identify autism in toddlers at an early stage. This will be done by applying a novel Random Forest (RF) Classifier and comparing its effectiveness with the Support Vector Machine (SVM) classifier. Both algorithms are evaluated using different training and testing splits to provide predictions about the features of Autism Spectrum Disorder in young children. The Gpower test, with parameters $\alpha=0.05$ and power $=0.80$, confirms an $80 \\%$ confidence level. Results show that Novel RF achieves higher accuracy of $96.4020 \\%$ compared to SVM of 90.5010\% for the toddler dataset. An Independent sample t-test, conducted for statistical analysis, demonstrates a substantial disparity (p=0.007, p<0.05) in the performance of Novel RF and SVM. Thus, the accuracy of Novel RF outperforms SVM. Overall, Novel RF of $96.4020 \\%$ demonstrates superior performance compared to SVM of 90.5010\% in detecting autism traits in toddlers.",
    keywords = "Support vector machines;Training;Pediatrics;Autism;Accuracy;Statistical analysis;Vectors;Novel Random Forest Classifier;Support Vector Machine;Autism Spectrum Disorder(ASD);Disability;Children;ML",
    doi = "10.1109/ICITIIT61487.2024.10580412",
    issn = "",
    month = "March"
}

